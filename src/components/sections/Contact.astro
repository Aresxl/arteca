---
// Data

// Images
import PhoneIcon from "@/assets/icons/phone.svg";
import EmailIcon from "@/assets/icons/email.svg";
import HomeIcon from "@/assets/icons/home.svg";
import SuccessIcon from "@/assets/icons/checkmark.svg";
import ErrorIcon from "@/assets/icons/cross.svg";

// Components
import LinkOrButton from "../ui/LinkOrButton.astro";
import ItalicTitle from "../ui/ItalicTitle.astro";
---

<section class="contact | grid-main">
  <div class="contact__inner">
    <div class="contact__info fade-in">
      <header class="contact__intro">
        <p class="eyebrow eyebrow--gold">Contact Vyteca</p>
        <h2 class="section-subtitle section-subtitle--light">
          Let's fill your <ItalicTitle variant="on-dark">tables.</ItalicTitle>
        </h2>
        <p class="contact__lead">
          Tell me about your Melbourne venue and what you're after.
          <strong> I reply within 24 hours,</strong> same day for calls.
        </p>
      </header>

      <ul class="contact__details-list">
        <li class="contact__details-item">
          <a class="contact__detail" href="tel:+61430811413">
            <span class="icon__wrapper">
              <PhoneIcon class="contact__icon" width="20" height="20" aria-hidden="true" />
            </span>
            <span class="contact__content">
              <span class="contact__content-title">Phone</span>
              <span class="contact__content-value">+61 430 811 413</span>
            </span>
          </a>
        </li>
        <li class="contact__details-item">
          <a class="contact__detail" href="mailto:vyteca@gmail.com">
            <span class="icon__wrapper">
              <EmailIcon class="contact__icon" width="20" height="20" aria-hidden="true" />
            </span>
            <span class="contact__content">
              <span class="contact__content-title">Email</span>
              <span class="contact__content-value">Click to email</span>
            </span>
          </a>
        </li>
        <li class="contact__details-item">
          <div class="contact__detail">
            <span class="icon__wrapper">
              <HomeIcon class="contact__icon" width="20" height="20" aria-hidden="true" />
            </span>
            <span class="contact__content">
              <span class="contact__content-title">Location</span>
              <span class="contact__content-value">Melbourne</span>
            </span>
          </div>
        </li>
      </ul>

      <p class="contact__availability">
        <span class="contact__availability-dot" aria-hidden="true"></span>
        Taking on new venues this quarter
      </p>
    </div>

    <div class="form__wrapper fade-in">
      <noscript>
        <p class="form__noscript">
          JavaScript needs to be on to send this form. You can also reach us directly using the
          phone or email details on this page.
        </p>
      </noscript>
      <form class="form" method="post" novalidate>
        <span class="contact__corner contact__corner--tl" aria-hidden="true"></span>
        <span class="contact__corner contact__corner--tr" aria-hidden="true"></span>
        <span class="contact__corner contact__corner--bl" aria-hidden="true"></span>
        <span class="contact__corner contact__corner--br" aria-hidden="true"></span>

        <div class="form__control form__control--pair">
          <label for="name">
            <span>Name</span>
            <span class="asterix" aria-hidden="true">*</span>
          </label>
          <div class="input__wrapper">
            <input
              type="text"
              id="name"
              name="name"
              placeholder="Bob"
              autocomplete="name"
              aria-describedby="error-name"
              data-input
              required
            />
            <div class="icon__wrapper">
              <SuccessIcon class="icon icon--success" width="24" height="24" aria-hidden="true" />
              <ErrorIcon class="icon icon--error" width="24" height="24" aria-hidden="true" />
            </div>
          </div>
          <span class="error-message" data-error-for="name" aria-live="polite" id="error-name"
          ></span>
        </div>

        <div class="form__control form__control--pair">
          <label for="venue-name">
            <span>Venue name</span>
            <span class="asterix" aria-hidden="true">*</span>
          </label>
          <div class="input__wrapper">
            <input
              type="text"
              id="venue-name"
              name="venue-name"
              placeholder="Bob's Burger Joint"
              autocomplete="organization"
              aria-describedby="error-venue-name"
              data-input
              required
            />
            <div class="icon__wrapper">
              <SuccessIcon class="icon icon--success" width="24" height="24" aria-hidden="true" />
              <ErrorIcon class="icon icon--error" width="24" height="24" aria-hidden="true" />
            </div>
          </div>
          <span
            class="error-message"
            data-error-for="venue-name"
            aria-live="polite"
            id="error-venue-name"></span>
        </div>

        <div class="form__control">
          <label for="email">
            <span>Email</span>
            <span class="asterix" aria-hidden="true">*</span>
          </label>
          <div class="input__wrapper">
            <input
              type="email"
              id="email"
              name="email"
              placeholder="example@gmail.com"
              autocomplete="email"
              aria-describedby="error-email"
              data-input
              required
            />
            <div class="icon__wrapper">
              <SuccessIcon class="icon icon--success" width="24" height="24" aria-hidden="true" />
              <ErrorIcon class="icon icon--error" width="24" height="24" aria-hidden="true" />
            </div>
          </div>
          <span class="error-message" data-error-for="email" aria-live="polite" id="error-email"
          ></span>
        </div>

        <div class="form__control">
          <label for="phone">
            <span>Phone</span>
            <span class="optional">(optional)</span>
          </label>
          <div class="input__wrapper">
            <input
              type="tel"
              id="phone"
              name="phone"
              placeholder="0430 811 413"
              inputmode="tel"
              autocomplete="tel"
              aria-describedby="error-phone"
              data-input
            />
            <div class="icon__wrapper">
              <SuccessIcon class="icon icon--success" width="24" height="24" aria-hidden="true" />
              <ErrorIcon class="icon icon--error" width="24" height="24" aria-hidden="true" />
            </div>
          </div>
          <span class="error-message" data-error-for="phone" aria-live="polite" id="error-phone"
          ></span>
        </div>

        <fieldset>
          <legend>
            <span>Contact preference</span>
            <span class="asterix" aria-hidden="true">*</span>
          </legend>
          <div class="radio__wrapper">
            <label for="email-preference">
              <input
                type="radio"
                id="email-preference"
                name="contact"
                value="contact-email"
                aria-describedby="error-contact"
                checked
                required
              />
              <span class="checkbox"></span>
              <span>Email</span>
            </label>

            <label for="phone-preference">
              <input
                type="radio"
                id="phone-preference"
                name="contact"
                value="contact-phone"
                aria-describedby="error-contact"
              />
              <span class="checkbox"></span>
              <span>Phone call</span>
            </label>

            <label for="no-preference">
              <input
                type="radio"
                id="no-preference"
                name="contact"
                value="contact-none"
                aria-describedby="error-contact"
              />
              <span class="checkbox"></span>
              <span>No preference</span>
            </label>
          </div>
          <span class="error-message" data-error-for="contact" aria-live="polite" id="error-contact"
          ></span>
        </fieldset>

        <div class="form__control">
          <label for="message" class="message-label">
            <span>Message</span>
            <span class="asterix" aria-hidden="true">*</span>
            <div class="icon__wrapper">
              <SuccessIcon class="icon icon--success" width="24" height="24" aria-hidden="true" />
              <ErrorIcon class="icon icon--error" width="24" height="24" aria-hidden="true" />
            </div>
          </label>
          <div class="input__wrapper">
            <textarea
              class="form-input"
              name="message"
              id="message"
              rows="4"
              aria-describedby="error-message-input"
              placeholder="A few lines about your venue and what you're after."
              data-input
              required></textarea>
          </div>
          <span class="char-count" data-char-count aria-hidden="true"></span>
          <span
            class="error-message"
            data-error-for="message"
            aria-live="polite"
            id="error-message-input"></span>
        </div>

        <div class="fax__wrapper" aria-hidden="true">
          <label for="fax">Leave this field empty if you're a human</label>
          <input type="text" name="fax" id="fax" value="" tabindex="-1" autocomplete="off" />
        </div>

        <div class="contact__submit">
          <LinkOrButton as="button" text="Send message" type="submit" variant="primary" />
        </div>
        <p class="contact__fineprint">
          No obligation. I'll only use your details to reply to this enquiry.
        </p>
        <p class="form__status" role="alert" data-form-status hidden></p>
      </form>

      <dialog class="modal" data-success-modal aria-labelledby="modal-title">
        <div class="modal-content">
          <h2 class="modal-title" id="modal-title">Submission Complete 🚀</h2>
          <p data-modal-message></p>
          <LinkOrButton
            as="button"
            text="Got it"
            variant="primary"
            type="button"
            data-close-modal
          />
        </div>
      </dialog>
    </div>
  </div>
</section>

<style>
  /* ───────────────────────────────────────────────
     Section-scoped helpers. The default --clr-border-default
     (hsl 26 16% 8%) is near-invisible on the dark background,
     so the column rules and field outlines get a brighter,
     gold-tied border token — same fix as TripleGuarantee.
  ─────────────────────────────────────────────── */
  .contact {
    --c-gold: var(--clr-primary-gold);
    --c-border: hsl(30, 6%, 24%);
    --c-border-hover: var(--clr-body-muted);
    --c-gold-tint: color-mix(in srgb, var(--clr-primary-gold) 8%, transparent);
    --c-gold-hover: color-mix(in srgb, var(--clr-primary-gold) 4%, transparent);
    --c-gold-ring: color-mix(in srgb, var(--clr-primary-gold) 20%, transparent);
    --c-gold-inset: color-mix(in srgb, var(--clr-primary-gold) 10%, transparent);

    /* functional state colours — warm axis, tuned to the editorial palette */
    --c-ok: oklch(66% 0.115 152);
    --c-ok-bg: oklch(66% 0.115 152 / 0.08);
    --c-err: oklch(60% 0.145 30);
    --c-err-bg: oklch(60% 0.145 30 / 0.08);

    position: relative;
    background-color: var(--clr-bg-primary-dark);
    /* margin-block: var(--spacing-2xl) var(--section-space); */
    padding-block: var(--section-space);
  }

  .contact__inner {
    display: grid;
    gap: var(--spacing-2xl);
  }

  .contact__intro {
    text-align: center;
  }

  /* ── left: info column ── */

  .contact__lead {
    margin-top: var(--spacing-md);
    font-size: var(--fs-400);
    line-height: 1.7;
    color: var(--clr-body-muted-light);
  }

  .contact__lead strong {
    color: var(--clr-body-text);
    font-weight: var(--fw-700);
  }

  .contact__details-list {
    display: flex;
    flex-direction: column;
    margin-top: var(--spacing-xl);
    border: 1px solid var(--c-border);
  }

  .contact__detail {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    border-bottom: 1px solid var(--c-border);
    color: inherit;
    transition: background-color 0.4s var(--ease);
  }

  .contact__details-item:last-child .contact__detail {
    border-bottom: none;
  }

  /* gold bar sweeps down on hover — the homepage card hover (see OurOfferCard) */
  .contact__detail::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--c-gold);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.55s var(--ease);
  }

  .contact__detail .icon__wrapper {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    flex-shrink: 0;
    border: 1px solid var(--c-border);
    border-radius: 3px;
    color: var(--c-gold);
    transition:
      border-color 0.4s var(--ease),
      background-color 0.4s var(--ease),
      transform 0.4s var(--ease);
  }

  .contact__content {
    display: grid;
    gap: 2px;
  }

  .contact__content-title {
    font-size: var(--fs-300);
    font-weight: var(--fw-700);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--clr-body-muted-light);
  }

  .contact__content-value {
    font-weight: var(--fw-400);
    color: var(--clr-body-text);
    transition: color 0.3s var(--ease);
  }

  /* hover — every row reacts (decorative, like the homepage cards) */
  .contact__detail:hover {
    background-color: var(--c-gold-hover);
  }

  .contact__detail:hover::before {
    transform: scaleY(1);
  }

  .contact__detail:hover .icon__wrapper {
    border-color: var(--c-gold);
    background-color: var(--c-gold-tint);
    transform: translateY(-2px);
  }

  .contact__detail:hover .contact__content-value {
    color: var(--c-gold);
  }

  /* focus ring only on the genuinely interactive rows */
  a.contact__detail:focus-visible {
    outline: 2px solid var(--c-gold);
    outline-offset: 4px;
  }

  .contact__availability {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xs);
    margin-top: var(--spacing-lg);
    font-size: var(--fs-300);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--clr-body-muted-light);
  }

  .contact__availability-dot {
    position: relative;
    flex-shrink: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-gold);
  }

  /* compositor-only pulse (transform + opacity), never box-shadow */
  .contact__availability-dot::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--c-gold);
    animation: contactPulse 2.6s ease-in-out infinite;
  }

  @keyframes contactPulse {
    0% {
      transform: scale(1);
      opacity: 0.55;
    }
    70%,
    100% {
      transform: scale(2.8);
      opacity: 0;
    }
  }

  /* ── right: form panel ── */
  .form__wrapper {
    position: relative;
  }

  .form {
    position: relative;
    display: grid;
    /* top-align cells so an error message under one field doesn't stretch
       its row-mate (the name/venue pair) */
    align-items: start;
    gap: var(--spacing-sm);
    padding: var(--spacing-lg) var(--spacing-md);
    background-color: var(--clr-bg-card);
    border: 1px solid var(--c-border);
    border-radius: 3px;
  }

  /* corner brackets */
  .contact__corner {
    position: absolute;
    z-index: 2;
    width: 14px;
    height: 14px;
    opacity: 0.55;
    pointer-events: none;
  }

  .contact__corner::before,
  .contact__corner::after {
    content: "";
    position: absolute;
    background: var(--c-gold);
  }

  .contact__corner::before {
    width: 1px;
    height: 100%;
  }

  .contact__corner::after {
    width: 100%;
    height: 1px;
  }

  .contact__corner--tl {
    top: -1px;
    left: -1px;
  }
  .contact__corner--tl::before,
  .contact__corner--tl::after {
    top: 0;
    left: 0;
  }

  .contact__corner--tr {
    top: -1px;
    right: -1px;
  }
  .contact__corner--tr::before,
  .contact__corner--tr::after {
    top: 0;
    right: 0;
  }

  .contact__corner--bl {
    bottom: -1px;
    left: -1px;
  }
  .contact__corner--bl::before,
  .contact__corner--bl::after {
    bottom: 0;
    left: 0;
  }

  .contact__corner--br {
    bottom: -1px;
    right: -1px;
  }
  .contact__corner--br::before,
  .contact__corner--br::after {
    bottom: 0;
    right: 0;
  }

  .form__control {
    display: grid;
    gap: var(--spacing-xs);
  }

  .input__wrapper {
    position: relative;
  }

  input,
  textarea {
    --input-primary-clr: var(--clr-primary-gold);

    width: 100%;
    padding: var(--spacing-xs) var(--spacing-sm);
    border: 1px solid var(--c-border);
    border-radius: 3px;
    background-color: var(--clr-bg-primary-dark);
    color: var(--clr-body-text);
    outline: none;
    transition:
      border-color 0.3s var(--ease),
      box-shadow 0.3s var(--ease),
      background-color 0.3s var(--ease);
  }

  /* room for the state icon sitting inside the input wrapper */
  .input__wrapper input {
    padding-inline-end: 2.75rem;
  }

  .form__control textarea {
    resize: block;
    min-height: 8rem;
    line-height: 1.6;
  }

  .form__control input::placeholder,
  .form__control textarea::placeholder {
    color: var(--clr-body-muted);
    font-size: var(--fs-350);
  }

  /* hover + focus (active) states */
  input:hover,
  textarea:hover {
    border-color: var(--c-border-hover);
  }

  input:focus-visible,
  textarea:focus-visible,
  .radio__wrapper label:has(input[type="radio"]:focus-visible) {
    border-color: var(--input-primary-clr);
    box-shadow:
      0 0 0 3px var(--c-gold-ring),
      inset 0 0 15px var(--c-gold-inset);
  }

  .form__control label,
  legend {
    font-size: var(--fs-350);
    font-weight: var(--fw-700);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--clr-body-muted-light);
  }

  .asterix {
    color: var(--c-gold);
  }

  .optional {
    margin-left: var(--spacing-xxs);
    font-weight: var(--fw-400);
    text-transform: none;
    letter-spacing: normal;
    color: var(--clr-body-muted);
  }

  /* ── preference radio group ── */
  fieldset {
    padding: 0;
    border: 0;
    margin: 0;
  }

  .radio__wrapper {
    display: grid;
    gap: var(--spacing-xs);
    margin-block-start: var(--spacing-xs);
  }

  .radio__wrapper input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  .radio__wrapper label {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-xs) var(--spacing-sm);
    border: 1px solid var(--c-border);
    border-radius: 3px;
    background-color: var(--clr-bg-primary-dark);
    color: var(--clr-body-muted-light);
    cursor: pointer;
    transition:
      border-color 0.3s var(--ease),
      background-color 0.3s var(--ease),
      color 0.3s var(--ease);
  }

  .radio__wrapper label:hover {
    border-color: var(--c-border-hover);
  }

  /* selected (active) preference */
  .radio__wrapper label:has(input[type="radio"]:checked) {
    border-color: var(--c-gold);
    background-color: var(--c-gold-tint);
    color: var(--clr-body-text);
  }

  .checkbox {
    position: relative;
    display: grid;
    place-items: center;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    border: 1.5px solid var(--clr-body-muted);
    border-radius: 2px;
    transition: border-color 0.3s var(--ease);
  }

  .checkbox::before {
    content: "";
    width: 10px;
    height: 10px;
    border-radius: 1px;
    background: var(--c-gold);
    transform: scale(0);
    transition: transform 0.25s var(--ease);
  }

  input:checked ~ .checkbox {
    border-color: var(--c-gold);
  }

  input:checked ~ .checkbox::before {
    transform: scale(1);
  }

  /* ── submit + fineprint ── */
  .contact__submit {
    display: grid;
    margin-top: var(--spacing-xs);
  }

  .contact__fineprint {
    font-size: var(--fs-300);
    text-align: center;
    color: var(--clr-body-muted);
  }

  /* form-level status — populated by JS on a failed send */
  .form__status {
    font-size: var(--fs-350);
    text-align: center;
    color: var(--c-err);
  }

  /* no-JS fallback notice (sits above the form) */
  .form__noscript {
    margin-bottom: var(--spacing-sm);
    padding: var(--spacing-sm);
    border: 1px solid var(--c-border);
    border-radius: 3px;
    font-size: var(--fs-350);
    color: var(--clr-body-muted-light);
  }

  /* ═══════════════════════════════════════════════
     Success + error states.
  ═══════════════════════════════════════════════ */
  .icon {
    display: none;
  }

  .icon--success {
    color: var(--c-ok);
  }
  .icon--error {
    color: var(--c-err);
  }

  /* scoped under .form__control so the state border wins over the
     base input:hover / :focus-visible rules above */
  .form__control .error-input {
    border-color: var(--c-err);
    background-color: var(--c-err-bg);
  }

  .form__control .error-input:focus-visible {
    border-color: var(--c-err);
    box-shadow:
      0 0 0 3px color-mix(in srgb, var(--c-err) 22%, transparent),
      inset 0 0 15px color-mix(in srgb, var(--c-err) 8%, transparent);
  }

  .form__control .success-input {
    border-color: var(--c-ok);
    background-color: var(--c-ok-bg);
  }

  .form__control .success-input:focus-visible {
    border-color: var(--c-ok);
    box-shadow:
      0 0 0 3px color-mix(in srgb, var(--c-ok) 22%, transparent),
      inset 0 0 15px color-mix(in srgb, var(--c-ok) 8%, transparent);
  }

  .error-message {
    margin-block-start: var(--spacing-xxs);
    font-size: var(--fs-350);
    color: var(--c-err);
  }

  .success-message {
    margin-block-start: var(--spacing-xxs);
    font-size: var(--fs-350);
    color: var(--c-ok);
  }

  /* live message counter — muted until the minimum is cleared, then green */
  .char-count {
    justify-self: end;
    font-size: var(--fs-300);
    color: var(--clr-body-muted);
    font-variant-numeric: tabular-nums;
  }

  .char-count--ok {
    color: var(--c-ok);
  }

  /* error state for the radio group (no .form__control wrapper to colour) */
  fieldset.has-error legend {
    color: var(--c-err);
  }

  .form__control.has-success .icon--success {
    display: block;
  }
  .form__control.has-error .icon--error {
    display: block;
  }

  .form .icon__wrapper {
    position: absolute;
    top: 50%;
    right: 12px;
    transform: translateY(-50%);
  }

  .message-label {
    position: relative;
  }

  /* honeypot — kept in the DOM so bots still fill it, but removed from
     view, the accessibility tree (aria-hidden) and the tab order. */
  .fax__wrapper {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  /* ── success modal (native <dialog>, top layer) ── */
  .modal {
    margin: auto; /* centre in the top layer */
    width: min(30rem, calc(100% - 2 * var(--page-padding)));
    padding: var(--spacing-xl);
    border: 1px solid var(--c-border);
    border-radius: 3px;
    background-color: var(--clr-bg-secondary);
    color: var(--clr-body-text);
    text-align: center;
  }

  .modal::backdrop {
    background: hsl(0 0% 0% / 0.6);
    backdrop-filter: blur(12px);
  }

  .modal-content {
    display: grid;
    gap: var(--spacing-md);
  }

  .modal-title {
    font-size: var(--fs-600);
    font-weight: var(--fw-700);
    color: var(--clr-body-text);
  }
  /* ═══════════════════ end success/error block ═══════════════════ */

  /* ── responsive ── */
  @media (min-width: 30rem) {
    .contact__intro {
      text-align: left;
    }

    .contact__availability {
      justify-content: start;
    }
  }

  @media (min-width: 40rem) {
    .form {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-md);
      padding: var(--spacing-xl);
    }

    /* fields span the full panel by default… */
    .form > .form__control,
    .form > fieldset,
    .form > .fax__wrapper,
    .form > .contact__submit,
    .form > .contact__fineprint,
    .form > .form__status {
      grid-column: 1 / -1;
    }

    /* …name + venue sit side by side */
    .form > .form__control--pair {
      grid-column: auto;
    }

    .contact__lead {
      max-width: 53ch;
    }
  }

  @media (min-width: 62.5rem) {
    .contact__inner {
      grid-template-columns: 0.85fr 1.15fr;
      gap: var(--spacing-3xl);
      align-items: start;
    }

    .contact__info {
      position: sticky;
      top: 6rem;
    }
  }

  /* ── reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .contact__detail,
    .contact__detail::before,
    .contact__detail .icon__wrapper,
    .contact__content-value,
    .checkbox,
    .checkbox::before,
    input,
    textarea,
    .radio__wrapper label {
      transition: none;
    }

    .contact__availability-dot::after {
      animation: none;
    }
  }
</style>

<script>
  import { actions, isInputError } from "astro:actions";

  declare global {
    interface Window {
      dataLayer: Record<string, unknown>[];
    }
  }

  function initContact() {
    const form = document?.querySelector<HTMLFormElement>(`.form`);
    // Bail on routes without this form. The astro:page-load listener is global,
    // so this runs on every navigation, including pages with no contact form.
    if (!form) return;

    // Re-queried each navigation: <body> is fully replaced on swap, so any node
    // cached at module load would point at a detached element.
    const liveFields = document.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
      `[data-input]`,
    );

    const controller = new AbortController();
    const { signal } = controller;

    // Shared minimum for the message field — keep validation + counter in sync
    const MESSAGE_MIN = 50;
    const messageField = document.querySelector<HTMLTextAreaElement>(`#message`);
    const charCountEl = document.querySelector<HTMLElement>(`[data-char-count]`);

    function updateCharCount() {
      if (!messageField || !charCountEl) return;
      const len = messageField.value.trim().length;
      charCountEl.textContent = `${len} / ${MESSAGE_MIN}`;
      charCountEl.classList.toggle(`char-count--ok`, len >= MESSAGE_MIN);
    }

    messageField?.addEventListener(`input`, updateCharCount, { signal });
    updateCharCount();

    let formStarted = false;
    form?.addEventListener(
      "focusin",
      (e) => {
        if (formStarted) return;
        if (!(e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement))
          return;
        formStarted = true;
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: "form_start" });
      },
      { signal },
    );

    function setFieldError(fieldName: string, message: string | null) {
      const inputEl = document.querySelector<HTMLInputElement>(`[name="${fieldName}"]`);
      const control = inputEl?.closest(`.form__control, fieldset`);
      const errorMessageEl = document.querySelector<HTMLSpanElement>(
        `[data-error-for="${fieldName}"]`,
      );
      inputEl?.classList.add(`error-input`);
      inputEl?.setAttribute(`aria-invalid`, `true`);
      control?.classList.add(`has-error`);

      if (!errorMessageEl) return;
      errorMessageEl.textContent = message ?? "";
    }

    function setFieldSuccess(fieldName: string) {
      resetField(fieldName);

      const inputEl = document.querySelector(`[name="${fieldName}"]`);
      const control = inputEl?.closest(`.form__control`);

      inputEl?.classList.add(`success-input`);
      control?.classList.add(`has-success`);
    }

    function resetField(fieldName: string) {
      const inputEl = document.querySelector(`[name="${fieldName}"]`);
      const control = inputEl?.closest(`.form__control, fieldset`);
      const errorMessageEl = document.querySelector(`[data-error-for="${fieldName}"]`);

      control?.classList.remove(`has-error`, `has-success`);
      inputEl?.classList.remove(`error-input`, `success-input`);
      inputEl?.removeAttribute(`aria-invalid`);
      if (errorMessageEl) errorMessageEl.textContent = "";
    }

    function resetForm() {
      const controlEls = document.querySelectorAll(`.form__control, fieldset`);
      const inputEls = document.querySelectorAll(`[data-input]`);
      const errorMessageEls = document.querySelectorAll(`[data-error-for]`);

      // Clear classes
      controlEls.forEach((el) => {
        el.classList.remove(`has-error`, `has-success`);
      });
      inputEls.forEach((el) => {
        (el as HTMLInputElement | HTMLTextAreaElement).value = "";
        el.classList.remove(`error-input`, `success-input`);
      });
      errorMessageEls.forEach((el) => {
        el.textContent = "";
      });

      updateCharCount();
    }

    // Submission UI handles, resolved once
    const submitBtn = form?.querySelector<HTMLButtonElement>(`button[type="submit"]`);
    const submitDefaultText = submitBtn?.textContent?.trim() || "Send message";
    const formStatusEl = document.querySelector<HTMLElement>(`[data-form-status]`);
    const modalEl = document.querySelector<HTMLDialogElement>(`[data-success-modal]`);
    const modalMessageEl = document.querySelector<HTMLElement>(`[data-modal-message]`);
    const modalCloseBtnEl = document.querySelector<HTMLButtonElement>(`[data-close-modal]`);

    function setSubmitting(isSubmitting: boolean) {
      if (!submitBtn) return;
      submitBtn.disabled = isSubmitting;
      submitBtn.textContent = isSubmitting ? "Sending…" : submitDefaultText;
    }

    function showFormStatus(message: string) {
      if (!formStatusEl) return;
      formStatusEl.textContent = message;
      formStatusEl.hidden = false;
    }

    function clearFormStatus() {
      if (!formStatusEl) return;
      formStatusEl.textContent = "";
      formStatusEl.hidden = true;
    }

    function openSuccessModal(name: string, venueName: string) {
      if (modalMessageEl) {
        modalMessageEl.textContent = `Thanks for reaching out, ${name}! Your enquiry for ${venueName} is on its way. I'll get back to you within 24 hours. Check your inbox (and spam folder) just in case.`;
      }
      modalEl?.showModal();
    }

    // Close via the button, the Esc key (native <dialog>), or a click on the backdrop
    modalCloseBtnEl?.addEventListener(`click`, () => modalEl?.close(), { signal });
    modalEl?.addEventListener(
      `click`,
      (e) => {
        if (e.target === modalEl) modalEl?.close();
      },
      { signal },
    );

    form?.addEventListener(
      `submit`,
      async (e) => {
        e.preventDefault();
        clearFormStatus();

        // Validate everything up front; block the send if anything is invalid
        let isFormValid = true;
        liveFields.forEach((field) => {
          validateAndUpdateField(field, true);
          const control = field.closest(".form__control");
          if (control?.classList.contains("has-error")) {
            isFormValid = false;
          }
        });

        // Contact preference (radio group — not a [data-input] field)
        if (form?.querySelector(`input[name="contact"]:checked`)) {
          resetField("contact");
        } else {
          setFieldError("contact", "Please select how you'd like us to contact you");
          isFormValid = false;
        }

        if (!isFormValid) {
          const firstError = document.querySelector(".has-error");
          if (firstError) firstError.scrollIntoView({ behavior: "smooth" });
          return;
        }

        const formData = new FormData(form);
        const data = Object.fromEntries(formData) as {
          name: string;
          "venue-name": string;
          phone?: string;
          email: string;
          contact: "contact-email" | "contact-phone" | "contact-none";
          message: string;
          fax?: string;
        };

        setSubmitting(true);

        try {
          const { error } = await actions.form(data);

          if (error) {
            if (isInputError(error)) {
              for (const [fieldName, message] of Object.entries(error.fields)) {
                setFieldError(fieldName, message[0]);
              }
              const firstError = document.querySelector(".has-error");
              if (firstError) firstError.scrollIntoView({ behavior: "smooth" });
              showFormStatus("Please fix the highlighted fields and try again.");
            } else if (error.code === "TOO_MANY_REQUESTS") {
              showFormStatus(error.message);
            } else {
              showFormStatus(
                "Sorry, I couldn't send your message. Please try again, or email me directly at vyteca@gmail.com.",
              );
            }
            return; // keep the user's input so they don't have to retype
          }

          // Success — record it, confirm it, then clear the form
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: "form_submission" });
          openSuccessModal(data.name, data["venue-name"]);
          resetForm();
        } catch (err) {
          console.error("Action error:", err);
          showFormStatus("Sorry, something went wrong on our end. Please try again in a moment.");
        } finally {
          setSubmitting(false);
        }
      },
      { signal },
    );

    liveFields.forEach((field) => {
      field.addEventListener(
        `input`,
        () => {
          validateAndUpdateField(field);
        },
        { signal },
      );
      field.addEventListener(
        `blur`,
        () => {
          validateAndUpdateField(field, true);
        },
        { signal },
      );
    });

    function validateAndUpdateField(
      field: HTMLInputElement | HTMLTextAreaElement,
      showErrorOnFail = false,
    ) {
      const name = field.name;
      const value = field.value.trim();
      let isValid = false;
      let errorMsg = "";

      resetField(name);

      // Optional + empty → stay neutral (no success tick, no error)
      if (!field.required && value === "") {
        return;
      }

      switch (name) {
        case `name`:
          isValid = value.length >= 2;
          errorMsg = `Please enter your name`;
          break;

        case `venue-name`:
          isValid = value.length >= 2;
          errorMsg = `Please enter your venue's name`;
          break;

        case `email`:
          isValid = value.length > 0 && /\S+@\S+\.\S+/.test(value);
          errorMsg = !value ? "Email can't be empty" : "Please enter a valid email";
          break;

        case "phone":
          if (!value) {
            isValid = true;
          } else {
            const digits = value.replace(/[^0-9+]/g, "");
            isValid = digits.length >= 9;
            errorMsg = "Please enter a valid phone number";
          }
          break;

        case "message":
          isValid = value.length >= MESSAGE_MIN;
          errorMsg = !value
            ? "Message can't be empty"
            : `Must be ${MESSAGE_MIN} characters or more`;
          break;

        default:
          isValid = value.length > 0;
      }

      if (isValid) {
        setFieldSuccess(name);
      } else {
        if (showErrorOnFail) {
          setFieldError(name, errorMsg);
        }
      }
    }

    // Drop the form's listeners before the next swap; the fresh form swapped in
    // gets its own bindings on the following astro:page-load.
    document.addEventListener(
      "astro:before-swap",
      () => {
        controller.abort();
      },
      { once: true },
    );
  }

  document.addEventListener("astro:page-load", initContact);
</script>
