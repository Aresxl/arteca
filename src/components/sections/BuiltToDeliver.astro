---
import SectionHeader from "../ui/SectionHeader.astro";
---

<section class="grid-main">
  <SectionHeader
    title="Built & Delivered"
    titleTag="h2"
    titleId="built-title"
    subtitle="Never worry about your website ever again"
    supportingText="100% custom. No templates. We build exactly what your Melbourne restaurant needs so you focus on the food and the tables."
  />
  <div class="card__wrapper">
    <div class="card">
      <ul class="features">
        <li class="feature">
          <div class="icon__wrapper"></div>
          <span class="feature__text">Bespoke design tailored to your menu, vibe and brand</span>
        </li>
        <li class="feature">
          <div class="icon__wrapper"></div>
          <span class="feature__text">Up to 5 core pages included (extra pages available)</span>
        </li>
        <li class="feature">
          <div class="icon__wrapper"></div>
          <span class="feature__text">Full hosting & domain setup handled for you</span>
        </li>
        <li class="feature">
          <div class="icon__wrapper"></div>
          <span class="feature__text">Easy CMS – update menus and specials yourself anytime</span>
        </li>
        <li class="feature">
          <div class="icon__wrapper"></div>
          <span class="feature__text">Google Analytics 4 configured with simple reporting</span>
        </li>
        <li class="feature">
          <div class="icon__wrapper"></div>
          <span class="feature__text">Full handover with training & video walkthrough</span>
        </li>
        <li class="feature">
          <div class="icon__wrapper"></div>
          <span class="feature__text">Priority support after launch</span>
        </li>
      </ul>
    </div>
  </div>
</section>
