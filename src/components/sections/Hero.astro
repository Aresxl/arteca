---
// Images
import ArrowIcon from "@/assets/icons/arrow-up-right.svg";

// Components
import LinkOrButton from "../ui/LinkOrButton.astro";
---

<section class="hero grid-main hero-bg" aria-labelledby="hero-title">
  <header class="hero__header">
    <div class="eyebrow__wrapper">
      <span class="eyebrow eyebrow--gold">Melbourne hospitality venues</span>
    </div>
    <div class="hero__header-content">
      <h1 class="hero-title" id="hero-title">
        <span class="hero-title-span">
          <span class="hero-word"><span class="hero-word__inner">Fill</span></span>{" "}
          <span class="hero-word"><span class="hero-word__inner">more</span></span>{" "}
          <span class="hero-word"><span class="hero-word__inner">tables.</span></span>
        </span>{" "}
        <span class="hero-italic"
          ><span class="hero-word"><span class="hero-word__inner">Guaranteed.</span></span></span
        >
      </h1>
      <p class="supporting__text">
        At least five new bookings a month, or you don't pay. Custom, hand-coded, and from
        $150/month with $0 upfront.
      </p>
      <div class="btn__wrapper">
        <LinkOrButton
          as="a"
          href="/free-designs"
          text="Get your 3 free designs"
          variant="primary"
          data-track="cta"
        >
          <ArrowIcon />
        </LinkOrButton>
        <LinkOrButton as="a" href="/portfolio" text="View work" variant="secondary" />
      </div>
    </div>
  </header>

  <canvas class="hero-canvas" id="hero-canvas" aria-hidden="true"></canvas>
  <svg
    class="hero-flair"
    aria-hidden="true"
    focusable="false"
    viewBox="0 0 560 560"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <radialGradient id="hero-flair-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--clr-primary-gold)" stop-opacity="0.16"></stop>
        <stop offset="50%" stop-color="var(--clr-primary-gold)" stop-opacity="0.05"></stop>
        <stop offset="100%" stop-color="var(--clr-primary-gold)" stop-opacity="0"></stop>
      </radialGradient>
    </defs>

    <circle class="hero-flair__glow" cx="280" cy="280" r="220" fill="url(#hero-flair-glow)"
    ></circle>

    <circle class="hero-flair__ring hero-flair__ring--lg" cx="280" cy="280" r="279"></circle>
    <circle class="hero-flair__ring hero-flair__ring--md" cx="280" cy="280" r="209"></circle>
    <circle class="hero-flair__ring hero-flair__ring--sm" cx="280" cy="280" r="149"></circle>
    <circle class="hero-flair__ring hero-flair__ring--xs" cx="280" cy="280" r="89"></circle>

    <g class="hero-flair__orbit hero-flair__orbit--1">
      <circle class="hero-flair__dot" cx="280" cy="1" r="1.5"></circle>
    </g>
    <g class="hero-flair__orbit hero-flair__orbit--2">
      <circle class="hero-flair__dot hero-flair__dot--lg" cx="280" cy="71" r="2"></circle>
    </g>
    <g class="hero-flair__orbit hero-flair__orbit--3">
      <circle class="hero-flair__dot hero-flair__dot--sm" cx="280" cy="131" r="1"></circle>
    </g>
  </svg>

  <div class="hero-arc hero-arc--1" aria-hidden="true"></div>
  <div class="hero-arc hero-arc--2" aria-hidden="true"></div>
  <div class="hero-arc hero-arc--3" aria-hidden="true"></div>

  <span class="corner tl" aria-hidden="true"></span>
  <span class="corner tr" aria-hidden="true"></span>
  <span class="corner bl" aria-hidden="true"></span>
  <span class="corner br" aria-hidden="true"></span>

  <div class="hero__scroll-wrapper">
    <span class="hero__scroll-line"></span>
    <span class="hero__scroll-text">Scroll</span>
  </div>
</section>

<div class="hero-overlap-sentinel" aria-hidden="true"></div>

<style>
  /* The hero pins to the top and sits a layer below its in-flow siblings
     (z-index: -1, still above main's own background). The next opaque section
     then scrolls up and overlaps it. No scroll listeners, no per-frame work —
     the browser composites the pinned layer for free. */
  .hero {
    position: sticky;
    top: 0;
    overflow: hidden;
    z-index: -1;
    min-height: 93dvh;
    padding-block-start: var(--spacing-4xl);
  }

  .hero-overlap-sentinel {
    height: 1px;
  }

  .hero-canvas {
    grid-column: 1 / -1;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .hero__header {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .eyebrow__wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .eyebrow__dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--clr-primary-gold);
  }

  .hero-title-span {
    display: inline-block;
    margin-block-end: var(--spacing-xxs);
  }

  /* Clipping mask: the word slides up from behind this edge.
     .hero-title is line-height: 1, so we pad the bottom to give descenders
     and the underline room, plus the inline sides for the italic glyphs'
     slant overhang, then pull it back with matching negative margins so the
     headline's line spacing and word spacing don't shift. */
  .hero-word {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
    padding-inline: 0.12em;
    margin-block-end: -0.15em;
    margin-inline: -0.12em;
  }

  .hero-word__inner {
    display: inline-block;
  }

  .hero-italic {
    position: relative;
    color: var(--clr-body-muted-light);
    font-weight: var(--fw-400);
    font-style: italic;
  }

  .hero-italic::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 2px;
    background-color: var(--clr-primary-gold);
    transform-origin: left;
  }

  /* ── Hero load reveal ──────────────────────────────────────────
     Eyebrow / body / CTAs / scroll fade + slide in open space.
     Headline words rise out from behind their mask, then the gold
     underline draws last. */
  .eyebrow__wrapper,
  .supporting__text,
  .btn__wrapper {
    animation: hero-rise 0.9s var(--ease) both;
  }

  .hero-word__inner {
    animation: hero-word-rise 0.9s var(--ease) both;
  }

  .hero-title-span .hero-word:nth-child(1) .hero-word__inner {
    animation-delay: 0.12s;
  }
  .hero-title-span .hero-word:nth-child(2) .hero-word__inner {
    animation-delay: 0.2s;
  }
  .hero-title-span .hero-word:nth-child(3) .hero-word__inner {
    animation-delay: 0.28s;
  }
  .hero-italic .hero-word__inner {
    animation-delay: 0.36s;
  }
  .supporting__text {
    animation-delay: 0.55s;
  }
  .btn__wrapper {
    animation-delay: 0.7s;
  }
  .hero__scroll-wrapper {
    animation: hero-rise-scroll 0.9s var(--ease) 0.85s both;
  }
  /* Gold underline draws last, after the word has settled */
  .hero-italic::after {
    animation: hero-underline 1s var(--ease) 1.2s both;
  }

  /* During a page-transition navigation the shutter JS tags <html> so the
     entrance holds at its first frame beneath the sealed curtain, then plays as
     the curtain opens. JS-only and motion-only — a no-JS or reduced-motion visit
     animates on load (the reduced-motion block below clears these anyway). */
  @media (prefers-reduced-motion: no-preference) {
    :global(html.hold-entrance) .eyebrow__wrapper,
    :global(html.hold-entrance) .supporting__text,
    :global(html.hold-entrance) .btn__wrapper,
    :global(html.hold-entrance) .hero-word__inner,
    :global(html.hold-entrance) .hero__scroll-wrapper,
    :global(html.hold-entrance) .hero-italic::after {
      animation-play-state: paused;
    }
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-word-rise {
    from {
      opacity: 0;
      transform: translateY(120%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-rise-scroll {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }

  @keyframes hero-underline {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }

  .hero__header-content {
    margin-block-start: var(--spacing-lg);
  }

  .supporting__text {
    max-width: 30ch;
    margin-block-start: var(--spacing-md);
    margin-inline: auto;
    font-size: clamp(1rem, 0.9559859154929577rem + 0.18779342723004694vw, 1.125rem);
  }

  .btn__wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xs);
    margin-block-start: var(--spacing-xl);
  }

  .hero__scroll-wrapper {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: var(--clr-neutral-750);
    animation: scrollPulse 2s ease-in-out 1.5s infinite;
    transform-origin: top;
  }

  .hero__scroll-text {
    color: var(--clr-body-muted-light);
    font-size: var(--fs-200);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  /* Hero Corners (viewfinder frame) */
  .corner {
    position: absolute;
    z-index: 30;
    display: block;
    width: 20px;
    height: 20px;
    opacity: 0.28;
  }

  .corner::before,
  .corner::after {
    content: "";
    position: absolute;
    background: var(--clr-primary-gold);
  }

  .corner::before {
    width: 1px;
    height: 100%;
  }
  .corner::after {
    width: 100%;
    height: 1px;
  }
  .corner.tl {
    top: 30px;
    left: 10px;
  }
  .corner.tl::before {
    top: 0;
    left: 0;
  }
  .corner.tl::after {
    top: 0;
    left: 0;
  }
  .corner.tr {
    top: 30px;
    right: 10px;
  }
  .corner.tr::before {
    top: 0;
    right: 0;
  }
  .corner.tr::after {
    top: 0;
    right: 0;
  }
  .corner.bl {
    bottom: 30px;
    left: 10px;
  }
  .corner.bl::before {
    bottom: 0;
    left: 0;
  }
  .corner.bl::after {
    bottom: 0;
    left: 0;
  }
  .corner.br {
    bottom: 30px;
    right: 10px;
  }
  .corner.br::before {
    bottom: 0;
    right: 0;
  }
  .corner.br::after {
    bottom: 0;
    right: 0;
  }

  /* ── Hero Flair (SVG — rings + orbit dots) ─────────────────── */
  .hero-flair {
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    width: min(560px, 90vmin);
    height: min(560px, 90vmin);
    pointer-events: none;
    contain: layout style paint;    z-index: 1;
  }

  .hero-flair__ring {
    fill: none;
    stroke: var(--clr-primary-gold);
    stroke-width: 1;
  }
  .hero-flair__ring--lg {
    stroke-opacity: 0.07;
  }
  .hero-flair__ring--md {
    stroke-opacity: 0.09;
  }
  .hero-flair__ring--sm {
    stroke-opacity: 0.1;
  }
  .hero-flair__ring--xs {
    stroke-opacity: 0.12;
  }

  .hero-flair__orbit {
    transform-origin: 280px 280px;
  }

  .hero-flair__orbit--1 {
    animation: flair-spin 22s linear infinite;
  }
  .hero-flair__orbit--2 {
    animation: flair-spin 14s linear infinite reverse;
  }
  .hero-flair__orbit--3 {
    animation: flair-spin 9s linear infinite;
  }

  .hero-flair__dot {
    fill: var(--clr-primary-gold);
    fill-opacity: 0.7;
  }
  .hero-flair__dot--lg {
    fill-opacity: 0.9;
  }
  .hero-flair__dot--sm {
    fill-opacity: 0.5;
  }

  .hero-flair__glow {
    animation: glow-pulse 4s ease-in-out infinite;
  }

  @keyframes flair-spin {
    to {
      rotate: 1turn;
    }
  }

  @keyframes glow-pulse {
    0%,
    100% {
      opacity: 0.5;
    }
    50% {
      opacity: 1;
    }
  }

  .hero-arc {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    pointer-events: none;
    translate: -50% -50%;    z-index: 1;
  }

  .hero-arc::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
  }

  .hero-arc--1 {
    width: min(560px, 90vmin);
    height: min(560px, 90vmin);
    animation: flair-spin 18s linear infinite;
  }
  .hero-arc--1::before {
    background: conic-gradient(
      from 0deg,
      transparent 0%,
      transparent 55%,
      color-mix(in srgb, var(--clr-primary-gold) 15%, transparent) 72%,
      color-mix(in srgb, var(--clr-primary-gold) 5%, transparent) 88%,
      transparent 100%
    );
  }

  .hero-arc--2 {
    width: min(420px, 67.5vmin);
    height: min(420px, 67.5vmin);
    animation: flair-spin 32s linear infinite reverse;
  }
  .hero-arc--2::before {
    background: conic-gradient(
      from 180deg,
      transparent 0%,
      transparent 65%,
      color-mix(in srgb, var(--clr-primary-gold) 8%, transparent) 80%,
      transparent 100%
    );
  }

  .hero-arc--3 {
    width: min(300px, 48.21vmin);
    height: min(300px, 48.21vmin);
    animation: flair-spin 10s linear infinite;
    opacity: 0.6;
  }
  .hero-arc--3::before {
    background: conic-gradient(
      from 0deg,
      transparent 0%,
      transparent 55%,
      color-mix(in srgb, var(--clr-primary-gold) 15%, transparent) 72%,
      color-mix(in srgb, var(--clr-primary-gold) 5%, transparent) 88%,
      transparent 100%
    );
  }

  @media (min-width: 26.875rem) {
    .supporting__text {
      max-width: 37ch;
      margin-block-start: var(--spacing-xl);
    }

    .btn__wrapper {
      flex-direction: row;
    }
  }

  @media (min-width: 40rem) {
    .hero {
      padding-block: var(--spacing-5xl) var(--spacing-2xl);
    }

    .btn__wrapper {
      gap: var(--spacing-xl);
    }
  }

  @media (min-width: 48rem) {
    .hero__header-content {
      margin-inline: auto;
      margin-block-start: var(--spacing-xl);
    }
  }

  @media (min-width: 62.5rem) {
    .hero__header-content {
      margin-block-start: var(--spacing-2xl);
    }

    .hero-title {
      max-width: 18ch;
      margin-inline: auto;
    }

    .btn__wrapper {
      margin-block-start: var(--spacing-xl);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    /* Drop the scroll pinning but keep the hero positioned so its absolute
       children stay anchored to it. */
    .hero {
      position: relative;
    }

    .hero-arc,
    .hero-flair__orbit,
    .hero-flair__glow,
    .eyebrow__wrapper,
    .supporting__text,
    .btn__wrapper,
    .hero__scroll-wrapper,
    .hero__scroll-line,
    .hero-word__inner,
    .hero-italic::after {
      animation: none;
    }
  }
</style>

<script>
  function initHeroCanvas() {
    const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement | null;
    if (!canvas || window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const controller = new AbortController();
    const { signal } = controller;

    const ctx = canvas.getContext("2d")!;
    const GOLD = "225,189,104";

    // Particle density scales with viewport (rem breakpoints mirror the CSS:
    // 40rem/62.5rem/90rem). resize() reads this, so crossing a breakpoint
    // re-seeds the field at the new count for free.
    function getCount() {
      if (window.matchMedia("(min-width: 90rem)").matches) return 100;
      if (window.matchMedia("(min-width: 62.5rem)").matches) return 70;
      if (window.matchMedia("(min-width: 40rem)").matches) return 45;
      return 35;
    }

    let W = 0,
      H = 0,
      particles: { x: number; y: number; r: number; vx: number; vy: number; a: number }[] = [],
      rafId: number | null = null,
      onscreen = true,
      active = true;

    function rand(a: number, b: number) {
      return a + Math.random() * (b - a);
    }

    function resize() {
      const hero = canvas!.closest("section") as HTMLElement;
      W = canvas!.width = hero.offsetWidth;
      H = canvas!.height = hero.offsetHeight;
      particles = Array.from({ length: getCount() }, () => ({
        x: rand(0, W),
        y: rand(0, H),
        r: rand(0.5, 2.2),
        vx: rand(-0.09, 0.09),
        vy: rand(-0.07, 0.07),
        a: rand(0.1, 0.4),
      }));
    }

    // The drift is throttled to ~30fps. Each particle moves a fraction of a
    // pixel between native frames, so redrawing the whole canvas at a 144Hz
    // display is wasted rasterisation — 30fps looks identical here and cuts the
    // full-canvas repaints ~5x. Motion is time-based (referenced to one 144Hz
    // frame, the cadence the field was tuned at) so the real drift speed holds
    // steady on any refresh rate.
    const FRAME_MS = 1000 / 30;
    const BASE_MS = 1000 / 144;
    let lastFrame = 0;

    function draw(now: number) {
      if (active) rafId = requestAnimationFrame(draw);
      if (!lastFrame) lastFrame = now;
      const elapsed = now - lastFrame;
      if (elapsed < FRAME_MS) return;
      lastFrame = now - (elapsed % FRAME_MS);
      // Clamp the step so returning from a background tab can't teleport the
      // field: cap it at four 144Hz frames' worth of drift.
      const step = Math.min(elapsed / BASE_MS, 4);

      ctx.clearRect(0, 0, W, H);
      for (const p of particles) {
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${GOLD},${p.a})`;
        ctx.fill();
        p.x += p.vx * step;
        p.y += p.vy * step;
        if (p.x < 0) p.x = W;
        else if (p.x > W) p.x = 0;
        if (p.y < 0) p.y = H;
        else if (p.y > H) p.y = 0;
      }
    }

    function stop() {
      active = false;
      if (rafId !== null) {
        cancelAnimationFrame(rafId);
        rafId = null;
      }
    }

    function start() {
      if (active) return;
      active = true;
      lastFrame = 0;
      rafId = requestAnimationFrame(draw);
    }

    document.addEventListener(
      "visibilitychange",
      () => {
        if (document.hidden) stop();
        else if (onscreen) start();
      },
      { signal },
    );

    // The hero pins (position: sticky), so its own box never leaves the
    // viewport — observing the section would keep it "intersecting" forever.
    // Instead watch the sentinel that flows right after it: once it scrolls
    // above the top edge, the next section has fully covered the hero, so the
    // canvas can pause. It restarts when the hero is scrolled back into view.
    const sentinel = canvas.closest("section")!.nextElementSibling;
    let observer: IntersectionObserver | null = null;
    if (sentinel) {
      observer = new IntersectionObserver(
        ([e]) => {
          onscreen = e.boundingClientRect.top > 0;
          if (onscreen) start();
          else stop();
        },
        { threshold: 0 },
      );
      observer.observe(sentinel);
    }

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener(
      "resize",
      () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(resize, 150);
      },
      { signal },
    );

    resize();
    rafId = requestAnimationFrame(draw);

    // Tear down before the page is swapped away: stop the rAF loop, drop the
    // observer, and remove the window/document listeners via the controller.
    // Without this, navigating away would leak a running canvas loop per visit.
    document.addEventListener(
      "astro:before-swap",
      () => {
        stop();
        observer?.disconnect();
        clearTimeout(resizeTimer);
        controller.abort();
      },
      { once: true },
    );
  }

  document.addEventListener("astro:page-load", initHeroCanvas);
</script>
