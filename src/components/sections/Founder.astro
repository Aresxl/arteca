---
// The founder section — framed portrait + personal story. Redesigned, editorial
// (cream + gold) successor to About.astro. Drop a headshot in via the `image`
// prop; until one is supplied a labelled placeholder holds the 16:9 frame.
import type { ImageMetadata } from "astro";
import Picture from "astro/components/Picture.astro";
import ItalicTitle from "../ui/ItalicTitle.astro";

interface Props {
  /** Founder headshot, rendered at a 16:9 landscape ratio. */
  image?: ImageMetadata;
  imageAlt?: string;
}

const { image, imageAlt = "Lachlan, founder and developer at Vyteca" } = Astro.props;
---

<section class="founder | grid-main" aria-labelledby="founder-title">
  <header class="founder__head | fade-in">
    <h2 class="eyebrow eyebrow--dark" id="founder-title">The founder</h2>
    <p class="section-subtitle section-subtitle--dark">
      Meet <ItalicTitle variant="on-light">Lachlan.</ItalicTitle>
    </p>
  </header>

  <div class="founder__body">
    <figure class="founder__portrait | fade-in">
      <div class="founder__frame">
        <span class="founder__corner founder__corner--tl" aria-hidden="true"></span>
        <span class="founder__corner founder__corner--tr" aria-hidden="true"></span>
        <span class="founder__corner founder__corner--bl" aria-hidden="true"></span>
        <span class="founder__corner founder__corner--br" aria-hidden="true"></span>
        {
          image ? (
            <Picture
              src={image}
              formats={["avif", "webp"]}
              fallbackFormat="jpg"
              alt={imageAlt}
              widths={[400, 640, 860, 1100]}
              sizes="(min-width: 62.5rem) 28rem, min(90vw, 22rem)"
              class="founder__img"
              quality={90}
            />
          ) : (
            <div class="founder__placeholder" aria-hidden="true">
              <span>Headshot</span>
            </div>
          )
        }
      </div>
      <figcaption class="founder__caption">
        <span class="founder__caption-name">Lachlan</span>
        <span class="founder__caption-role">Founder · Developer</span>
      </figcaption>
    </figure>

    <div class="founder__story | fade-in">
      <p class="founder__lead">
        I'm the developer behind <ItalicTitle variant="on-light">every</ItalicTitle> Vyteca project.
      </p>
      <p class="founder__text">
        Most Melbourne hospitality venues are losing bookings without knowing it. Their site loads
        slowly on mobile, the menu takes three taps to find, and the booking button is buried below
        the fold. The visitor bounces. The table stays empty. And from the owner's side, everything
        looks fine.
      </p>
      <blockquote class="founder__pull">
        <p>That's the problem Vyteca was built to fix.</p>
      </blockquote>
      <p class="founder__text">
        I build custom, hand-coded websites exclusively for Melbourne restaurants, cafes, bars, and
        wine bars. Sites that load in under 1.5s, rank well locally, and make it effortless for
        someone to go from landing on your page to locking in a reservation.
      </p>
      <p class="founder__text">
        No templates. No drag-and-drop builders. No bloat. Just fast, clean builds that do one thing
        well: turn visitors into bookings.
      </p>
      <p class="founder__text">
        I handle every project personally, from the first call to launch day. You're never handed
        off to a junior or managed by a project coordinator.
      </p>
      <p class="founder__sign">
        <span class="founder__sign-line" aria-hidden="true"></span>
        One developer · Full accountability · Start to finish
      </p>
    </div>
  </div>
</section>

<style>
  .founder {
    padding-block: var(--section-space);
    background-color: var(--clr-bg-primary-light);
    color: var(--clr-body-text-dark);
  }

  .founder__head {
    margin-block-end: var(--spacing-xl);
    text-align: center;
  }

  .founder__body {
    display: grid;
    gap: var(--spacing-xl);
  }

  /* ── Portrait ──────────────────────────────────────────── */
  /* Capped so it never outgrows the story: ~22rem below desktop, then it
     fills its grid column (~30rem at the 75rem container). */
  .founder__portrait {
    margin: 0 auto;
    width: 100%;
    max-width: 28rem;
  }

  .founder__frame {
    position: relative;
    padding: 14px;
  }

  .founder__img,
  .founder__placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border: 1px solid var(--border-light);
  }

  /* Source is a portrait photo in a landscape frame — anchor the cover crop
     near the top so it holds the face + a hint of shoulder, not a chest band. */
  .founder__img {
    object-position: 50% 25%;
  }

  .founder__placeholder {
    display: grid;
    place-items: center;
    background-color: color-mix(in srgb, var(--clr-primary-gold) 8%, var(--clr-bg-primary-light));
    color: var(--clr-body-muted-light);
    font-size: var(--fs-300);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .founder__corner {
    position: absolute;
    width: 20px;
    height: 20px;
    opacity: 0.5;
  }

  .founder__corner::before,
  .founder__corner::after {
    content: "";
    position: absolute;
    background-color: var(--clr-primary-gold);
  }

  .founder__corner::before {
    width: 1px;
    height: 100%;
  }

  .founder__corner::after {
    width: 100%;
    height: 1px;
  }

  .founder__corner--tl {
    top: 0;
    left: 0;
  }
  .founder__corner--tr {
    top: 0;
    right: 0;
  }
  .founder__corner--tr::before,
  .founder__corner--tr::after {
    right: 0;
  }
  .founder__corner--bl {
    bottom: 0;
    left: 0;
  }
  .founder__corner--bl::before,
  .founder__corner--bl::after {
    bottom: 0;
  }
  .founder__corner--br {
    bottom: 0;
    right: 0;
  }
  .founder__corner--br::before,
  .founder__corner--br::after {
    bottom: 0;
    right: 0;
  }

  .founder__caption {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--spacing-sm);
    margin-block-start: var(--spacing-sm);
    padding-block-start: var(--spacing-xs);
    border-block-start: 1px solid var(--border-light);
  }

  .founder__caption-name {
    font-size: var(--fs-450);
    font-weight: var(--fw-700);
    color: var(--clr-body-text-dark);
  }

  .founder__caption-role {
    font-size: var(--fs-300);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--clr-body-muted-light);
  }

  /* ── Story ─────────────────────────────────────────────── */
  .founder__lead {
    font-size: clamp(1.25rem, 1.05rem + 0.85vw, 1.625rem);
    line-height: 1.4;
    color: var(--clr-body-text-dark);
    margin-block-end: var(--spacing-md);
  }

  .founder__text {
    font-size: var(--fs-400);
    line-height: 1.78;
    color: var(--clr-body-muted);
  }

  .founder__text + .founder__text {
    margin-block-start: var(--spacing-md);
  }

  .founder__pull {
    margin-block: var(--spacing-md);
    padding-inline-start: var(--spacing-md);
    border-inline-start: 2px solid var(--clr-primary-gold);
  }

  .founder__pull p {
    font-size: clamp(1.25rem, 1.05rem + 0.85vw, 1.625rem);
    font-style: italic;
    line-height: 1.34;
    color: var(--clr-body-text-dark);
  }

  .founder__sign {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-block-start: var(--spacing-md);
    font-size: var(--fs-300);
    font-weight: var(--fw-700);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--clr-body-muted);
  }

  .founder__sign-line {
    flex-shrink: 0;
    width: 34px;
    height: 1px;
    background-color: var(--clr-primary-gold);
  }

  /* ── Two-column, sticky portrait from tablet up ────────── */
  /* Starts at 48rem so the portrait never gets marooned in whitespace: the
     story column takes the extra width instead of enlarging the photo. */
  @media (min-width: 48rem) {
    .founder__body {
      grid-template-columns: 0.86fr 1.14fr;
      gap: clamp(2.5rem, 5vw, 4.75rem);
      align-items: start;
    }

    .founder__portrait {
      position: sticky;
      top: 6rem;
      max-width: none;
    }

    .founder__head {
      text-align: left;
    }
  }
</style>
