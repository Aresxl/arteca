---
import type { HTMLAttributes } from "astro/types";

const { num, title, text, ...rest } = Astro.props;

interface Props extends HTMLAttributes<"li"> {
  num: string;
  title: string;
  text: string;
}
---

<li class="offer-card" {...rest}>
  <div class="offer-card__title-row">
    <div class="offer-card-num">{num}</div>
    <span class="divider"></span>
    <h3 class="offer-card-title">{title}</h3>
  </div>
  <p class="offer-card-body">{text}</p>
</li>

<style>
  .offer-card {
    position: relative;
    padding: 16px 40px 36px;
    min-height: 220px;
    background: var(--clr-bg-secondary);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    overflow: hidden;
    cursor: default;
    transition: background 0.3s;
  }

  .offer-card:hover {
    background: hsl(0, 0%, 13%);
  }

  /* Gold bar sweeps down on hover */
  .offer-card::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--clr-primary-gold);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.55s var(--ease);
  }

  .offer-card:hover::before {
    transform: scaleY(1);
  }

  /* Gold shimmer sweep */
  .offer-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(196, 164, 90, 0.05) 50%,
      transparent 70%
    );
    transform: translateX(-100%);
    transition: transform 0.7s var(--ease);
    pointer-events: none;
  }

  .offer-card:hover::after {
    transform: translateX(100%);
  }

  .offer-card__title-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .offer-card-num {
    position: relative;
    order: 0;
    flex-shrink: 0;
    font-size: 1.5rem;
    font-weight: var(--fw-700);
    line-height: 1;
    color: var(--clr-primary-gold);
    letter-spacing: -0.03em;
    margin-block-end: 0;
    transition: color 0.3s;
  }

  .divider {
    height: 1px;
    width: 20px;
    background: rgba(255, 255, 255, 0.15);
  }

  .offer-card:hover .offer-card-num {
    color: rgba(196, 164, 90, 0.42);
  }

  .offer-card-title {
    order: 2;
    flex-shrink: 0;
    color: oklch(85% 0.008 62);
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1.25;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .offer-card-body {
    margin-block-start: 16px;
    font-size: 0.9375rem; /* 15px */
    color: var(--clr-body-muted-light);
    line-height: 1.72;
    text-wrap: pretty;
    /* Font-relative measure: holds a comfortable line length as the copy
       grows to 16px, instead of stranding text in the wider tablet card. */
    max-width: 52ch;
  }

  @media (prefers-reduced-motion: reduce) {
    .offer-card::before,
    .offer-card::after {
      transition: none;
    }
  }

  /* ── ≥640px: body copy settles at its final reading size ────────────────── */

  @media (min-width: 40rem) {
    .offer-card-body {
      font-size: 1rem; /* 16px */
    }
  }

  /* ── ≥768px: tablet — keep the inline "01 — Title" row, scale the number ─── */

  @media (min-width: 48rem) {
    .offer-card {
      padding: 20px 40px 36px;
    }

    .offer-card-num {
      font-size: 3rem;
    }
  }

  /* ── ≥1000px: desktop two-column — number stacks above the title ─────────── */

  @media (min-width: 62.5rem) {
    .offer-card {
      border-top: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .offer-card__title-row {
      display: block;
    }

    .offer-card-num {
      margin-block-end: 12px;
    }

    .offer-card-body {
      margin-block-start: 10px;
    }
  }
</style>
