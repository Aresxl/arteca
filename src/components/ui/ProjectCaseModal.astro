---
// Images
import ArrowUp from "@/assets/icons/arrow-up-right.svg";

import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import LinkOrButton from "./LinkOrButton.astro";

interface CaseProject {
  /** Stable key — must match the triggering card's `caseKey`. */
  id: string;
  title: string;
  eyebrow: string;
  text: string;
  pageSpeed: string;
  loadSpeed: string;
  /** e.g. "concept" | "live" — drives the status label. */
  type: string;
  websiteHref: string;
  websiteUrl: string;
  desktopImgSrc: ImageMetadata;
  mobileImgSrc: ImageMetadata;
}

interface Props {
  /** The projects to render as case-study panels, in display order. */
  projects: CaseProject[];
  /** Id base for the per-panel heading ids — keep unique if a page ever holds two modals. */
  idBase?: string;
  /** Colour surface the overlay sits on. */
  surface?: "dark" | "light";
}

const { projects, idBase = "case", surface = "dark" } = Astro.props;

// Split a trailing unit ("1.2s" → "1.2" + "s") so it can be styled smaller.
const splitLoad = (value: string) => {
  const parts = value.match(/^([\d.]+)(.*)$/);
  return { value: parts ? parts[1] : value, unit: parts ? parts[2] : "" };
};

const headingId = (id: string) => `${idBase}-name-${id}`;
---

{
  projects.length > 0 && (
    <dialog
      class:list={["case-modal", { "case-modal--light": surface === "light" }]}
      aria-labelledby={headingId(projects[0].id)}
    >
      <button type="button" class="case-modal__close" aria-label="Close case study">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
          <path
            d="M6 6 18 18M18 6 6 18"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
          />
        </svg>
      </button>

      <p class="sr-only" data-case-status aria-live="polite" />

      <div class="case-modal__viewport">
        {projects.map((project, i) => {
          const load = splitLoad(project.loadSpeed);
          return (
            <article
              class="case-modal__panel"
              data-key={project.id}
              data-title={project.title}
              hidden={i !== 0}
            >
              <div class="case-modal__media">
                <div class="case-modal__browser">
                  <div class="case-modal__bar" aria-hidden="true">
                    <span class="case-modal__dot" />
                    <span class="case-modal__dot" />
                    <span class="case-modal__dot" />
                    <span class="case-modal__url">{project.websiteUrl}</span>
                  </div>
                  <div class="case-modal__shot">
                    <Picture
                      src={project.desktopImgSrc}
                      alt={`Desktop view of the ${project.title} website`}
                      formats={["avif", "webp"]}
                      fallbackFormat="jpg"
                      width={1600}
                      height={1050}
                      fit="cover"
                      position="top"
                      widths={[600, 900, 1200, 1600, 1918]}
                      sizes="(min-width: 67.5rem) 600px, (min-width: 48rem) 58vw, 88vw"
                      loading="lazy"
                    />
                  </div>
                </div>

                <div class="case-modal__devices">
                  <div class="case-modal__phone">
                    <div class="case-modal__phone-screen">
                      <Picture
                        src={project.mobileImgSrc}
                        alt={`Mobile view of the ${project.title} website`}
                        formats={["avif", "webp"]}
                        fallbackFormat="jpg"
                        width={132}
                        densities={[2, 3]}
                        loading="lazy"
                      />
                    </div>
                  </div>
                  <p class="case-modal__devices-note">
                    <span class="case-modal__devices-label">Mobile first</span>
                    Diners search on their phones. Every Vyteca build is designed for the small
                    screen first.
                  </p>
                </div>
              </div>

              <div class="case-modal__info">
                <p class="case-modal__eyebrow">{project.eyebrow}</p>
                <h2 class="case-modal__name" id={headingId(project.id)}>
                  {project.title}
                </h2>
                <p class="case-modal__narrative">{project.text}</p>

                <dl class="case-modal__stats">
                  <div class="case-modal__stat">
                    <dt class="case-modal__stat-label">PageSpeed</dt>
                    <dd class="case-modal__stat-value">{project.pageSpeed}</dd>
                  </div>
                  <div class="case-modal__stat">
                    <dt class="case-modal__stat-label">Load time</dt>
                    <dd class="case-modal__stat-value">
                      {load.value}
                      {load.unit && <span class="case-modal__stat-unit">{load.unit}</span>}
                    </dd>
                  </div>
                </dl>

                <div class="case-modal__actions">
                  <LinkOrButton
                    as="a"
                    href={project.websiteHref}
                    variant="primary"
                    text="Visit site"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <ArrowUp width={12} height={12} />
                    <span class="sr-only">, opens in a new tab</span>
                  </LinkOrButton>
                </div>
              </div>
            </article>
          );
        })}
      </div>

      <div class="case-modal__nav-group">
        <button
          type="button"
          class="case-modal__nav case-modal__nav--prev"
          aria-label="Previous project"
        >
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
            <path
              d="M15 5 8 12l7 7"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </button>

        <button
          type="button"
          class="case-modal__nav case-modal__nav--next"
          aria-label="Next project"
        >
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
            <path
              d="M9 5l7 7-7 7"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </button>
      </div>
    </dialog>
  )
}

<style>
  /* ── Surface tokens (dark, default) ─────────────────────────────────────── */
  .case-modal {
    --case-bg: var(--clr-neutral-900);
    --case-media-bg: hsl(24 18% 4%);
    --case-frame-bg: hsl(24 14% 6%);
    --case-border: var(--border-dark);
    --case-border-soft: hsl(30 8% 15%);
    --case-text: var(--clr-body-text);
    --case-heading: hsl(30 10% 92%);
    --case-muted: var(--clr-body-muted-light);
    --case-gold: var(--clr-primary-gold);
    --case-control-bg: hsl(0 0% 8% / 0.72);
  }

  /* ── Surface tokens (light) ─────────────────────────────────────────────── */
  .case-modal--light {
    --case-bg: var(--clr-neutral-0);
    --case-media-bg: var(--clr-neutral-200);
    --case-frame-bg: var(--clr-neutral-0);
    --case-border: var(--border-light);
    --case-border-soft: var(--border-light);
    --case-text: var(--clr-body-text-dark);
    --case-heading: var(--clr-body-text-dark);
    --case-muted: var(--clr-body-muted-light);
    --case-control-bg: hsl(0 0% 100% / 0.7);
  }

  /* ── Dialog shell ───────────────────────────────────────────────────────── */
  .case-modal {
    /* Closed: fully removed from the page. The UA's dialog:not([open]) display:
       none is an author-overridable rule, and this component's styles would
       otherwise leave the dialog display:flex (a fixed, opacity:0 panel that
       still occupies the centre of the viewport and eats scroll/clicks). Open
       state restores display:flex; the allow-discrete display transition below
       animates the none↔flex flip so the exit fade still plays. */
    display: none;
    flex-direction: column;
    width: min(1180px, calc(100vw - 2.5rem));
    max-height: min(calc(100dvh - 2.5rem), 760px);
    padding: 0;
    border: 1px solid var(--case-border);
    border-radius: 6px;
    background: var(--case-bg);
    color: var(--case-text);
    overflow: hidden;

    /* Pin the centering explicitly. A modal dialog is centred by the UA's
       top-layer rules, but those only apply while it matches :modal. On close
       the open attribute drops immediately while the exit transition still
       keeps it painted (allow-discrete) — without this it would fall back to
       static document-flow positioning and visibly drop toward the bottom. */
    position: fixed;
    inset: 0;
    margin: auto;

    /* Entry/exit: fade + rise. display & overlay stay discrete so the exit
       animation can play before the dialog leaves the top layer. */
    opacity: 0;
    translate: 0 14px;
    transition:
      opacity 0.35s var(--ease),
      translate 0.4s var(--ease),
      overlay 0.4s var(--ease) allow-discrete,
      display 0.4s var(--ease) allow-discrete;
  }

  .case-modal[open] {
    display: flex;
    opacity: 1;
    translate: 0 0;
  }

  @starting-style {
    .case-modal[open] {
      opacity: 0;
      translate: 0 14px;
    }
  }

  .case-modal::backdrop {
    background: hsl(0 0% 2% / 0.72);
    backdrop-filter: blur(6px);
    opacity: 0;
    transition:
      opacity 0.4s var(--ease),
      overlay 0.4s var(--ease) allow-discrete,
      display 0.4s var(--ease) allow-discrete;
  }

  .case-modal[open]::backdrop {
    opacity: 1;
  }

  @starting-style {
    .case-modal[open]::backdrop {
      opacity: 0;
    }
  }

  /* Lock the page behind the open dialog. */
  :global(html.is-case-open) {
    overflow: hidden;
  }

  /* Continue the page film grain over the modal. A modal dialog lives in the
     browser's top layer, above body::after, so the page grain can't reach it.
     This mirrors body::after exactly. It's a static raster tile painted once on
     open (not an animated filter), pointer-events: none, and above the controls
     (z-index 3) so the texture stays uniform. */
  .case-modal::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    opacity: 0.088;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    background-size: 160px 160px;
  }

  /* ── Scroll container ───────────────────────────────────────────────────── */
  .case-modal__viewport {
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  /* ── Panels ─────────────────────────────────────────────────────────────── */
  .case-modal__panel {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
  }

  .case-modal__panel[hidden] {
    display: none;
  }

  /* ── Media column ───────────────────────────────────────────────────────── */
  .case-modal__media {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    background: var(--case-media-bg);
  }

  .case-modal__browser {
    border: 1px solid var(--case-border-soft);
    border-radius: 3px;
    overflow: hidden;
    background: var(--case-frame-bg);
  }

  .case-modal__bar {
    display: flex;
    align-items: center;
    gap: 7px;
    height: 36px;
    padding: 0 14px;
    background: var(--case-media-bg);
    border-bottom: 1px solid var(--case-border-soft);
  }

  .case-modal__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--case-muted);
    opacity: 0.5;
  }

  .case-modal__url {
    max-width: 70%;
    margin-inline: auto;
    padding: 3px 16px;
    border: 1px solid var(--case-border-soft);
    border-radius: 2px;
    font-size: var(--fs-200);
    letter-spacing: 0.08em;
    color: var(--case-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .case-modal__shot {
    position: relative;
    aspect-ratio: 16 / 10.5;
    /* On wide viewports the dialog grows toward its 1180px max and this fluid,
       fixed-ratio shot grows tall with it. Past ~1153px the media column (shot +
       bar + phone + padding) exceeds the dialog's 760px height cap and the
       viewport scrolls. Capping the shot height keeps the column within budget;
       object-fit: cover crops the extra cleanly rather than distorting. */
    max-height: 21rem;
    overflow: hidden;
    background: var(--case-frame-bg);
  }

  .case-modal__shot :global(picture) {
    position: absolute;
    inset: 0;
  }

  .case-modal__shot :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 0%;
  }

  /* ── Mobile companion ───────────────────────────────────────────────────── */
  .case-modal__devices {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    text-align: center;
  }

  .case-modal__phone {
    flex-shrink: 0;
    width: 132px;
    padding: 6px;
    border: 2px solid var(--case-border-soft);
    border-radius: 18px;
    background: hsl(0 0% 4%);
  }

  .case-modal__phone-screen {
    position: relative;
    aspect-ratio: 9 / 19;
    overflow: hidden;
    border-radius: 12px;
    background: var(--case-frame-bg);
  }

  .case-modal__phone-screen :global(picture) {
    position: absolute;
    inset: 0;
  }

  .case-modal__phone-screen :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 0%;
  }

  .case-modal__devices-note {
    font-size: var(--fs-400);
    line-height: 1.5;
    color: var(--case-muted);
  }

  .case-modal__devices-label {
    display: block;
    margin-block-end: 4px;
    font-size: var(--fs-300);
    font-weight: var(--fw-700);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--case-heading);
  }

  /* ── Info column ────────────────────────────────────────────────────────── */
  .case-modal__info {
    display: flex;
    flex-direction: column;
    padding: var(--spacing-lg);
  }

  .case-modal__eyebrow {
    font-size: var(--fs-300);
    font-weight: var(--fw-700);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--case-gold);
  }

  .case-modal__name {
    margin-block-start: 14px;
    font-size: clamp(1.75rem, 1.2rem + 2vw, 2.5rem);
    font-weight: var(--fw-700);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--case-heading);
  }

  /* Programmatic focus target — no persistent ring on click-through. */
  .case-modal__name:focus {
    outline: none;
  }

  .case-modal__name-accent {
    font-weight: var(--fw-400);
    font-style: italic;
    color: var(--case-muted);
  }

  .case-modal__narrative {
    margin-block-start: 22px;
    font-size: var(--fs-350);
    line-height: 1.8;
    color: var(--case-muted);
  }

  .case-modal__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    margin-block-start: 32px;
    border: 1px solid var(--case-border-soft);
    border-radius: 2px;
    overflow: hidden;
  }

  .case-modal__stat {
    display: flex;
    flex-direction: column-reverse;
    gap: 5px;
    padding: 18px 16px;
    border-right: 1px solid var(--case-border-soft);
  }

  .case-modal__stat:last-child {
    border-right: none;
  }

  .case-modal__stat-label {
    font-size: var(--fs-200);
    font-weight: var(--fw-700);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--case-muted);
  }

  .case-modal__stat-value {
    font-size: var(--fs-600);
    font-weight: var(--fw-700);
    letter-spacing: -0.02em;
    color: var(--case-heading);
  }

  .case-modal__stat-unit {
    font-size: var(--fs-400);
    font-weight: var(--fw-700);
    color: var(--case-muted);
  }

  .case-modal__actions {
    display: flex;
    align-items: center;
    /* gap: 22px; */
    gap: var(--spacing-xs);
    margin-block-start: auto;
    padding-block-start: 36px;
  }

  .btn--primary {
    min-height: auto;
  }

  /* ── Controls ───────────────────────────────────────────────────────────── */
  /* On the two-column layout the group is transparent, so the arrows position
     as absolute side controls against the dialog. The stacked layout turns it
     into a real flex bar (see the max-width: 60rem block). */
  .case-modal__nav-group {
    display: contents;
  }

  .case-modal__close,
  .case-modal__nav {
    position: absolute;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border: 1px solid var(--case-border-soft);
    border-radius: 3px;
    color: var(--case-text);
    background: var(--case-control-bg);
    backdrop-filter: blur(8px);
    cursor: pointer;
    transition:
      color 0.2s var(--ease),
      border-color 0.2s var(--ease);
  }

  .case-modal__close svg,
  .case-modal__nav svg {
    width: 18px;
    height: 18px;
  }

  .case-modal__close {
    top: 14px;
    right: 14px;
  }

  .case-modal__nav {
    top: 50%;
    translate: 0 -50%;
  }

  .case-modal__nav--prev {
    left: 0;
  }

  .case-modal__nav--next {
    right: 0;
  }

  .case-modal__close:hover,
  .case-modal__nav:hover,
  .case-modal__close:focus-visible,
  .case-modal__nav:focus-visible {
    color: var(--case-gold);
    border-color: var(--case-gold);
    outline: none;
  }

  @media (min-width: 25rem) {
    .case-modal__actions {
      gap: 22px;
    }
  }

  @media (min-width: 30rem) {
    .case-modal__devices {
      flex-direction: row;
      gap: var(--spacing-md);
      text-align: left;
      align-self: center;
    }

    .case-modal__devices-note {
      max-width: 35ch;
    }
  }

  @media (min-width: 48rem) {
    .case-modal__info {
      padding-inline-end: clamp(2rem, 3.5vw, 3rem);
      padding-block-end: 76px;
    }
  }

  /* ── Stack below the panel breakpoint ───────────────────────────────────── */
  @media (max-width: 60rem) {
    .case-modal__panel {
      grid-template-columns: 1fr;
    }

    /* Pull the controls out of the floating overlay into a real footer bar.
       As a flex sibling of the scroll area it reserves its own space, so the
       content can never scroll underneath the arrows. */
    .case-modal__nav-group {
      display: flex;
      flex-shrink: 0;
      justify-content: space-between;
      gap: 12px;
      padding: 12px clamp(1rem, 4vw, 1.5rem);
      background: var(--case-bg);
      border-top: 1px solid var(--case-border-soft);
    }

    .case-modal__nav {
      position: static;
      translate: none;
    }
  }

  /* ── Respect reduced-motion preferences ─────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .case-modal,
    .case-modal::backdrop {
      transition: none;
      opacity: 1;
      translate: none;
    }
  }
</style>

<script>
  function initProjectCaseModal() {
    const modal = document.querySelector<HTMLDialogElement>(".case-modal");
    // Bail on routes without this modal. The astro:page-load listener is global,
    // so this runs on every navigation, including pages that never render it.
    if (!modal) return;

    const panels = Array.from(modal.querySelectorAll<HTMLElement>(".case-modal__panel"));
    const viewport = modal.querySelector<HTMLElement>(".case-modal__viewport");
    const status = modal.querySelector<HTMLElement>("[data-case-status]");
    const closeBtn = modal.querySelector<HTMLButtonElement>(".case-modal__close");
    const prevBtn = modal.querySelector<HTMLButtonElement>(".case-modal__nav--prev");
    const nextBtn = modal.querySelector<HTMLButtonElement>(".case-modal__nav--next");
    const triggers = document.querySelectorAll<HTMLButtonElement>("[data-case-key]");

    const controller = new AbortController();
    const { signal } = controller;

    let current = 0;

    // Show one panel; `hidden` keeps the rest out of the layout and a11y tree.
    const render = (index: number) => {
      current = (index + panels.length) % panels.length;
      panels.forEach((panel, i) => {
        panel.hidden = i !== current;
      });

      const heading = panels[current].querySelector<HTMLElement>(".case-modal__name");
      if (heading?.id) modal.setAttribute("aria-labelledby", heading.id);
      if (status) status.textContent = `${panels[current].dataset.title ?? ""} case study`;
    };

    const open = (key: string) => {
      const index = panels.findIndex((panel) => panel.dataset.key === key);
      render(index === -1 ? 0 : index);
      document.documentElement.classList.add("is-case-open");
      modal.showModal();
      viewport?.scrollTo(0, 0);
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener(
        "click",
        () => {
          const key = trigger.dataset.caseKey;
          if (key) open(key);
        },
        { signal },
      );
    });

    // Warm every panel's images once the portfolio nears the viewport. They stay
    // lazy at initial paint (nothing competes with the hero/LCP), but by the time
    // a card is clicked the shots are fetched — so opening the modal and stepping
    // through projects with the arrows never flashes alt text on an unloaded image.
    const warmImages = () => {
      modal.querySelectorAll<HTMLImageElement>(".case-modal__panel img").forEach((img) => {
        img.loading = "eager";
      });
    };

    let warmObserver: IntersectionObserver | null = null;
    if (triggers.length > 0) {
      if ("IntersectionObserver" in window) {
        warmObserver = new IntersectionObserver(
          (entries, observer) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              warmImages();
              observer.disconnect();
            }
          },
          { rootMargin: "300px" },
        );
        triggers.forEach((trigger) => warmObserver!.observe(trigger));
      } else {
        warmImages();
      }
    }

    closeBtn?.addEventListener("click", () => modal.close(), { signal });
    prevBtn?.addEventListener("click", () => render(current - 1), { signal });
    nextBtn?.addEventListener("click", () => render(current + 1), { signal });

    // A click that lands on the dialog itself — its backdrop — dismisses it.
    modal.addEventListener(
      "click",
      (event) => {
        if (event.target === modal) modal.close();
      },
      { signal },
    );

    // Step through projects with the arrow keys while open.
    modal.addEventListener(
      "keydown",
      (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          render(current - 1);
        } else if (event.key === "ArrowRight") {
          event.preventDefault();
          render(current + 1);
        }
      },
      { signal },
    );

    // Close (button + native Escape) both fire "close" — unlock the page here.
    modal.addEventListener(
      "close",
      () => {
        document.documentElement.classList.remove("is-case-open");
      },
      { signal },
    );

    // Tear down before the page is swapped away: drop the warm observer and
    // remove every listener via the controller. The fresh modal swapped in
    // re-binds on the following astro:page-load.
    //
    // Also clear the scroll lock: `is-case-open` lives on <html>, which (unlike
    // <body>) is NOT replaced on swap. If the modal is open at navigation time,
    // the "close" event never fires, so without this the next page stays locked.
    document.addEventListener(
      "astro:before-swap",
      () => {
        document.documentElement.classList.remove("is-case-open");
        warmObserver?.disconnect();
        controller.abort();
      },
      { once: true },
    );
  }

  document.addEventListener("astro:page-load", initProjectCaseModal);
</script>
