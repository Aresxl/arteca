---
interface Props {
  tierLabel: string;
  cardTitle: string;
  cardSubtitle: string;
  features: string[];
  badges?: string[];
  isFoundation?: boolean;
  inherits?: boolean;
  inheritedFrom?: string;
  inheritedFeatures?: string;
  michelin?: boolean;
  popular?: boolean;
}

const {
  tierLabel,
  cardTitle,
  cardSubtitle,
  features,
  badges,
  inherits = false,
  inheritedFrom,
  inheritedFeatures,
  isFoundation = false,
  michelin = false,
  popular = false,
  ...rest
} = Astro.props;

// Images
import CheckmarkIcon from "@/assets/icons/success.svg";

// Components
import Heading from "./Heading.astro";
---

<li
  class:list={[
    "card__wrapper",
    popular && "card__wrapper--popular",
    michelin && "card__wrapper--michelin",
    isFoundation && "card__wrapper--foundation",
    ,
  ]}
>
  <div class:list={["card", !popular && "card--default", "fade-in"]}>
    <span class="tier">{tierLabel}</span>

    {
      michelin && (
        <>
          <span class="bracket bracket--top" />
          <span class="bracket bracket--bottom" />
        </>
      )
    }

    <Heading tag="h3" text={cardTitle} class="package-title" />
    <p class="card__subtitle">{cardSubtitle}</p>

    {
      isFoundation && (
        <>
          <div class="includes-divider">
            <div class="includes-divider__line" />
            <span class="includes-divider__label">Includes</span>
            <div class="includes-divider__line" />
          </div>
        </>
      )
    }

    {
      inherits && (
        <>
          <div class:list={["inheritance-block", michelin && "inheritance-block--michelin"]}>
            <span class="inheritance-block__tier">&#9664; {inheritedFrom}</span>
            <span class="inheritance-block__count">{inheritedFeatures} </span>
          </div>
          <div class:list={["plus-separator", michelin && "plus-separator--michelin"]}>
            <div class="plus-separator__line" />
            <span class="plus-separator__icon">+</span>
            <div class="plus-separator__line" />
          </div>
        </>
      )
    }

    <ul class="features__list">
      {
        features.map((feature, i) => (
          <li class="feature__item">
            <div class="left__wrapper">
              <span class:list={["feature__num"]}>0{i + 1}</span>
              <span class="feature__text">{feature}</span>
            </div>
            <div class="icon__wrapper">
              <CheckmarkIcon class="checkmark-icon" width="24" height="24" aria-hidden="true" />
            </div>
          </li>
        ))
      }
    </ul>
    <div class="badges__wrapper">
      {badges?.map((badge, i) => <span class="badge">{badge}</span>)}
    </div>

    <div class="dot-bg"></div>
  </div>
</li>

<style>
  .card__wrapper {
    position: relative;
    --primary-card-clr: var(--cyber-cyan-500);
  }

  .card__wrapper--michelin {
    --primary-card-clr: var(--cyber-yellow-500);
  }
  .card__wrapper--foundation {
    --primary-card-clr: var(--cyber-magenta-500);
  }

  .card__wrapper--popular {
    /* prettier-ignore */
    filter: 
    drop-shadow(0 0 1px color-mix(in srgb, var(--primary-card-clr) 100%, transparent))
    drop-shadow(0 0 2px color-mix(in srgb, var(--primary-card-clr) 80%, transparent)),
    drop-shadow(0 0 8px color-mix(in srgb, var(--primary-card-clr) 30%, transparent));

    animation: pulse-filter 3s ease-in-out infinite;
    will-change: transform, filter;
  }

  .card__wrapper--popular .card {
    box-shadow:
      inset 0 0 1px color-mix(in srgb, var(--primary-card-clr) 100%, transparent),
      inset 0 0 5px color-mix(in srgb, var(--primary-card-clr) 100%, transparent),
      inset 0 0 30px color-mix(in srgb, var(--primary-card-clr) 30%, transparent);
  }

  .card {
    position: relative;
    padding: var(--spacing-sm) var(--spacing-sm) var(--spacing-md);
    /* padding: 2rem 1.5rem; */
    background-color: var(--cyber-void-400);

    clip-path: polygon(
      0 0,
      calc(100% - 20px) 0,
      100% 20px,
      100% 100%,
      20px 100%,
      0 calc(100% - 20px)
    );
  }

  .card--default {
    border: 1px solid var(--clr-border-default);
    box-shadow:
      inset 0 0 30px color-mix(in srgb, var(--primary-card-clr) 10%, transparent),
      0 0 30px color-mix(in srgb, var(--primary-card-clr) 30%, transparent);
  }

  .card--default:before,
  .card--default:after {
    content: "";
    position: absolute;
    width: 30px;
    height: 30px;
    border: 2px solid var(--primary-card-clr);
    pointer-events: none;
  }

  .card--default:before {
    top: -1px;
    left: -1px;
    border-right: none;
    border-bottom: none;
  }

  .card--default:after {
    right: -1px;
    bottom: -1px;
    border-top: none;
    border-left: none;
  }

  .card__wrapper--popular .package-title {
    text-shadow: var(--glow-text-cyan);
  }

  .tier {
    display: block;
    margin-block-end: var(--spacing-md);
    /* color: var(--primary-card-clr); */
    /* font-weight: var(--fw-700); */
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  .package-title {
    position: relative;
    font-size: var(--fs-600);
    font-weight: var(--fw-700);
    letter-spacing: 2px;
    color: var(--primary-card-clr);
    /* text-shadow: var(--glow-text-cyan); */
  }

  .package-title::after {
    content: "";
    position: absolute;
    bottom: -15px;
    left: 0;
    width: 100%;
    height: 2px;

    background-color: hsl(from var(--primary-card-clr) h s l / 0.3);
    box-shadow: 0 0 8px hsl(from var(--primary-card-clr) h s l / 0.9);
  }

  .card__subtitle {
    margin-block-start: var(--spacing-lg);
  }

  .features__list {
    display: grid;
    gap: var(--spacing-sm);
    margin-block: var(--spacing-lg) var(--spacing-xl);
  }

  .feature__item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .feature__item:not(:last-child)::after {
    content: "";
    position: absolute;
    bottom: -10px;
    left: 0;
    width: 100%;
    height: 1px;

    /* background-color: hsl(from var(--cyber-cyan-500) h s l / 0.2);
    box-shadow: 0 0 8px hsl(from var(--cyber-cyan-500) h s l / 0.5); */

    background-color: hsl(from var(--clr-border-default) h s l / 0.3);
  }

  .left__wrapper {
    display: flex;
    gap: var(--spacing-sm);
    align-items: center;
  }

  .feature__num {
    /* color: var(--primary-card-clr); */
    color: color-mix(in srgb, var(--primary-card-clr) 55%, transparent);

    font-size: var(--fs-350);
  }

  .feature__text {
    font-size: var(--fs-375);
    /* line-height: 1.2; */
  }

  .checkmark-icon {
    width: 24px;
    height: 24px;
    color: var(--primary-card-clr);
    filter: drop-shadow(0 0 8px var(--primary-card-clr));
  }

  .dot-bg {
    grid-column: 1 / -1;
    position: absolute;
    inset: 0;
    z-index: 200;
    pointer-events: none;
    background-image: url(/images/dot-bg.png);
    background-repeat: repeat;
    opacity: 0.5;
  }

  .badges__wrapper {
    display: grid;
    gap: var(--spacing-xs);
    justify-content: start;
  }

  .badge {
    display: inline-block;
    width: max-content;
    padding: 4px 10px;
    border: 1px solid var(--primary-card-clr);
    background-color: hsl(from var(--primary-card-clr) h s l / 0.1);
    color: var(--primary-card-clr);
    text-transform: uppercase;

    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
  }

  /* Inner nested brackets — Michelin Star only, rendered as real elements */
  .bracket {
    position: absolute;
    width: 18px;
    height: 18px;
    border: 2px solid var(--primary-card-clr);
    pointer-events: none;
    z-index: 10;
    opacity: 0.65;
  }

  .bracket--top {
    top: 6px;
    left: 6px;
    border-right: none;
    border-bottom: none;
  }

  .bracket--bottom {
    bottom: 6px;
    right: 6px;
    border-top: none;
    border-left: none;
  }

  /* --- Foundation: INCLUDES divider --- */

  .includes-divider {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-block: var(--spacing-md) var(--spacing-sm);
  }

  .includes-divider__line {
    flex: 1;
    height: 1px;
    background-color: color-mix(in srgb, var(--primary-card-clr) 20%, transparent);
  }

  .includes-divider__label {
    flex-shrink: 0;
    color: color-mix(in srgb, var(--primary-card-clr) 45%, transparent);
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }

  /* --- Inheritance block (Signature & Michelin Star) --- */

  .inheritance-block {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    background-color: color-mix(in srgb, var(--primary-card-clr) 4%, transparent);
    border-left: 2px solid color-mix(in srgb, var(--primary-card-clr) 35%, transparent);
    padding: 0.5rem 0.75rem;
    margin-block: var(--spacing-md) var(--spacing-sm);
  }

  .inheritance-block--michelin {
    background-color: color-mix(in srgb, var(--primary-card-clr) 4%, transparent);
    border-left-color: color-mix(in srgb, var(--primary-card-clr) 35%, transparent);
  }

  .inheritance-block__tier {
    font-size: var(--fs-300, 0.6rem);
    color: color-mix(in srgb, var(--primary-card-clr) 70%, transparent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .inheritance-block--michelin .inheritance-block__tier {
    color: color-mix(in srgb, var(--primary-card-clr) 70%, transparent);
  }

  .inheritance-block__count {
    font-size: var(--fs-350, 0.73rem);
    color: rgb(140 170 175 / 0.8);
  }

  /* --- Plus separator --- */

  .plus-separator {
    display: flex;
    align-items: center;
    margin-block-end: var(--spacing-sm);
  }

  .plus-separator__line {
    flex: 1;
    height: 1px;
    background-color: color-mix(in srgb, var(--primary-card-clr) 30%, transparent);
  }

  .plus-separator--michelin .plus-separator__line {
    background-color: color-mix(in srgb, var(--cyber-yellow-500) 30%, transparent);
  }

  .plus-separator__icon {
    padding-inline: 0.5rem;
    font-size: 1rem;
    line-height: 1;
    color: color-mix(in srgb, var(--primary-card-clr) 60%, transparent);
  }

  .plus-separator--michelin .plus-separator__icon {
    color: color-mix(in srgb, var(--cyber-yellow-500) 60%, transparent);
  }

  @media (min-width: 40rem) {
    .card {
      height: 100%;
    }

    h3 {
      font-size: 20px;
    }
  }

  @media (min-width: 62.5rem) {
    .card {
      padding: 1.5rem;
    }

    .card__wrapper--popular {
      scale: 1.05;
    }

    .features__list {
      gap: 26px;
    }
  }
</style>
