---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  afterSrc: ImageMetadata;
  afterAlt: string;
  beforeSrc: ImageMetadata;
  beforeAlt: string;
  afterLabel?: string;
  beforeLabel?: string;
  eager?: boolean;
}

const {
  afterSrc,
  afterAlt,
  beforeSrc,
  beforeAlt,
  afterLabel = "VYTECA",
  beforeLabel = "Before",
  eager = false,
} = Astro.props;
---

<div class="ba">
  <div class="ba__panel">
    <span class="ba__label ba__label--before" aria-hidden="true">{beforeLabel}</span>
    <span class="ba__label ba__label--after" aria-hidden="true">{afterLabel}</span>

    <div class="ba__after-wrap">
      <Picture
        src={afterSrc}
        alt={afterAlt}
        formats={["avif", "webp"]}
        fallbackFormat="jpg"
        widths={[640, 960, 1280]}
        sizes="(min-width: 90rem) 1200px, (min-width: 40rem) 80vw, 100vw"
        loading={eager ? "eager" : "lazy"}
      />
    </div>
    <div class="ba__before-clip">
      <div class="ba__before-wrap">
        <Picture
          src={beforeSrc}
          alt={beforeAlt}
          formats={["avif", "webp"]}
          fallbackFormat="jpg"
          widths={[640, 960, 1280]}
          sizes="(min-width: 90rem) 1200px, (min-width: 40rem) 80vw, 100vw"
          loading={eager ? "eager" : "lazy"}
        />
      </div>
    </div>

    <div
      class="ba__handle"
      role="slider"
      aria-label="Before/after comparison slider"
      aria-valuenow="42"
      aria-valuemin="8"
      aria-valuemax="92"
      tabindex="0"
    >
      <div class="ba__handle-grip">
        <svg
          viewBox="0 0 14 14"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          focusable="false"
        >
          <path d="M2 7l3-3v6L2 7zm10 0l-3-3v6l3-3z"></path>
        </svg>
      </div>
    </div>
  </div>

  <p class="ba__hint">Drag or use arrow keys to compare</p>
</div>

<style>
  .ba {
    --ba-gold: var(--clr-primary-gold);
    --ba-border: var(--border-light);
    --ba-radius: 3px;
  }

  /* ── Panel ──────────────────────────────── */

  .ba__panel {
    --pct: 42%;

    position: relative;
    border: 1px solid var(--ba-border);
    border-radius: var(--ba-radius);
    overflow: hidden;
    user-select: none;
    aspect-ratio: 16 / 8.5;
  }

  /* ── Image wrappers ─────────────────────── */

  .ba__after-wrap,
  .ba__before-wrap {
    position: absolute;
    inset: 0;
  }

  .ba__after-wrap :global(picture),
  .ba__after-wrap :global(img),
  .ba__before-wrap :global(picture),
  .ba__before-wrap :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ba__before-clip {
    position: absolute;
    inset: 0;
    clip-path: inset(0 calc(100% - var(--pct)) 0 0);
  }

  /* ── Labels ─────────────────────────────── */

  .ba__label {
    position: absolute;
    top: var(--spacing-sm);
    z-index: 10;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 4px 9px;
    border-radius: 2px;
    font-weight: var(--fw-700);
    pointer-events: none;
  }

  .ba__label--before {
    left: var(--spacing-sm);
    background: hsl(0 0% 100% / 0.12);
    color: hsl(0 0% 100% / 0.5);
    border: 1px solid hsl(0 0% 100% / 0.12);
  }

  .ba__label--after {
    right: var(--spacing-sm);
    background: var(--ba-gold);
    color: var(--clr-bg-primary-dark);
  }

  /* ── Handle ─────────────────────────────── */

  .ba__handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: calc(var(--pct) - 1px);
    width: 2px;
    background: var(--ba-gold);
    z-index: 10;
    cursor: ew-resize;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ba__handle:focus-visible {
    outline: 2px solid var(--ba-gold);
    outline-offset: 4px;
  }

  .ba__handle-grip {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--ba-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ba__handle-grip svg {
    fill: var(--clr-bg-primary-dark);
    width: 14px;
    height: 14px;
  }

  /* ── Hint ───────────────────────────────── */

  .ba__hint {
    text-align: center;
    font-size: var(--fs-200);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--clr-body-muted);
    margin-block-start: var(--spacing-sm);
  }
</style>

<script>
  const roots = document.querySelectorAll<HTMLElement>(".ba");

  roots.forEach((root) => {
    const panel = root.querySelector<HTMLElement>(".ba__panel");
    const handle = root.querySelector<HTMLElement>(".ba__handle");

    if (!panel || !handle) return;

    let dragging = false;

    function setPct(clientX: number) {
      const rect = panel!.getBoundingClientRect();
      let p = ((clientX - rect.left) / rect.width) * 100;
      p = Math.max(8, Math.min(92, p));
      panel!.style.setProperty("--pct", `${p}%`);
      handle!.setAttribute("aria-valuenow", String(Math.round(p)));
    }

    // ── Mouse drag ───────────────────────────────
    handle.addEventListener("mousedown", (e) => {
      dragging = true;
      e.preventDefault();
    });

    panel.addEventListener("mousedown", (e) => {
      dragging = true;
      setPct(e.clientX);
      e.preventDefault();
    });

    window.addEventListener("mousemove", (e) => {
      if (dragging) setPct(e.clientX);
    });

    window.addEventListener("mouseup", () => {
      dragging = false;
    });

    // ── Touch drag ───────────────────────────────
    handle.addEventListener("touchstart", () => { dragging = true; }, { passive: true });

    window.addEventListener(
      "touchmove",
      (e) => { if (dragging) setPct(e.touches[0].clientX); },
      { passive: true }
    );

    window.addEventListener("touchend", () => {
      dragging = false;
    });

    // ── Keyboard on handle ───────────────────────
    handle.addEventListener("keydown", (e) => {
      if (e.key !== "ArrowLeft" && e.key !== "ArrowRight") return;
      e.preventDefault();
      const current = parseFloat(panel!.style.getPropertyValue("--pct") || "42");
      const next = Math.max(8, Math.min(92, current + (e.key === "ArrowRight" ? 5 : -5)));
      panel!.style.setProperty("--pct", `${next}%`);
      handle!.setAttribute("aria-valuenow", String(Math.round(next)));
    });
  });
</script>
