---
import type { HTMLAttributes } from "astro/types";

interface AnchorProps extends HTMLAttributes<"a"> {
  as?: "a";
  href: string;
  text: string;
  variant: "primary" | "secondary" | "card";
  /* Recolour a primary button for cream/light surfaces (e.g. the "What we
     offer" rail). No-op on other variants. */
  onLight?: boolean;
}

interface ButtonProps extends HTMLAttributes<"button"> {
  as: "button";
  text: string;
  type?: "submit" | "reset" | "button";
  variant: "primary" | "secondary";
  onLight?: boolean;
}

type Props = AnchorProps | ButtonProps;
const props = Astro.props as Props;

const { as, text, variant, onLight, color, ...rest } = Astro.props;

const inferredAs = "href" in props ? "a" : (as ?? "button");
---

{
  inferredAs === "a" ? (
    <a
      class:list={["btn", `btn--${variant}`, { "btn--on-light": onLight && variant === "primary" }]}
      data-magnetic={variant === "primary" ? "" : undefined}
      {...rest}
    >
      {text}
      <slot />
    </a>
  ) : (
    <button
      class:list={["btn", `btn--${variant}`, { "btn--on-light": onLight && variant === "primary" }]}
      data-magnetic={variant === "primary" ? "" : undefined}
      {...rest}
    >
      {text}
      <slot />
    </button>
  )
}

<style>
  .btn {
    --btn-padding-inline: 1.25rem;

    display: inline-flex;
    gap: var(--spacing-xxs);
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding-block: 0.5rem;
    padding-inline: var(--btn-padding-inline);
    background: transparent;
    font-weight: var(--fw-700);
    font-family: var(--ff-main);
    cursor: pointer;
  }

  /* Optional trailing icon, passed as a slotted <svg>. Sized in em so it tracks
     the label, and left to inherit colour (the icon must paint with
     currentColor) so it transitions alongside the button on hover. The base
     .btn already supplies the gap, so nothing shifts when no icon is passed.
     :global() is required: slotted markup keeps the *consumer's* style scope,
     not this component's, so a plain `.btn svg` selector would never match. It
     stays scoped under .btn, so it can't leak to unrelated SVGs. */
  .btn :global(svg) {
    width: 1.05em;
    height: 1.05em;
    flex-shrink: 0;
  }

  /* Magnetic-pull + lift channels. Registered so `transform` transitions
     smoothly when JS updates --btn-mx / --btn-my, and so they carry a typed
     0 rest value. JS only ever touches --btn-mx / --btn-my. */
  @property --btn-mx {
    syntax: "<length>";
    inherits: false;
    initial-value: 0px;
  }
  @property --btn-my {
    syntax: "<length>";
    inherits: false;
    initial-value: 0px;
  }
  @property --btn-lift {
    syntax: "<length>";
    inherits: false;
    initial-value: 0px;
  }

  .btn--primary {
    /* Colour channels. Defaults target a dark background (the common case);
       a surface variant only overrides these tokens, never the mechanics. */
    --btn-bg: var(--clr-body-text);
    --btn-border: var(--clr-body-text);
    --btn-fg: var(--clr-neutral-900);
    --btn-bg-hover: transparent;
    --btn-border-hover: var(--clr-primary-gold);
    --btn-fg-hover: var(--clr-primary-gold);
    --btn-shadow-hover:
      0 0 0 1px rgba(196, 164, 90, 0.12), 0 6px 28px rgba(196, 164, 90, 0.14),
      0 2px 8px rgba(0, 0, 0, 0.4);

    border-radius: 3px;
    background-color: var(--btn-bg);
    border: 1.5px solid var(--btn-border);
    color: var(--btn-fg);

    /* Cursor pull (JS) composed with the hover lift (CSS). Translate only:
       no layout, no paint, no CLS. Identity at rest, so no idle GPU layer. */
    transform: translate(var(--btn-mx, 0px), calc(var(--btn-my, 0px) + var(--btn-lift, 0px)));

    transition:
      background 0.45s var(--ease),
      color 0.45s var(--ease),
      border-color 0.45s var(--ease),
      transform 0.3s var(--ease),
      box-shadow 0.45s var(--ease);
  }

  .btn--primary:hover {
    background: var(--btn-bg-hover);
    color: var(--btn-fg-hover);
    border-color: var(--btn-border-hover);
    --btn-lift: -3px;
    box-shadow: var(--btn-shadow-hover);

    /* Justified, scoped promotion: the button is transform-animated for the
       entire hover (cursor tracking). Released on pointer-leave with :hover. */
    will-change: transform;
  }

  .btn--primary:active {
    --btn-lift: -1px;
  }

  /* Light-surface variant: the cream "What we offer" rail. Rest inverts to a
     dark fill so it still reads as primary on cream; hover swaps to the gold
     accent (on dark, that gold lives in the outline instead — but gold text on
     cream fails contrast, so here the gold moves to the fill). Same shape, lift,
     magnetic pull, and transitions — only the colours change. */
  .btn--primary.btn--on-light {
    --btn-bg: var(--clr-neutral-900);
    --btn-border: var(--clr-neutral-900);
    --btn-fg: var(--clr-neutral-200);
    --btn-bg-hover: var(--clr-primary-gold);
    --btn-border-hover: var(--clr-primary-gold);
    --btn-fg-hover: var(--clr-neutral-900);
    /* A gold glow is near-invisible on cream (warm-on-warm, both light), so the
       lift comes from a real layered drop shadow warmed toward the brand brown
       rather than flat grey. Tight contact shadow for definition + two broader
       ambient layers that actually register against the 93%-light surface. */
    --btn-shadow-hover:
      0 1px 2px rgba(54, 37, 9, 0.28), 0 6px 14px rgba(54, 37, 9, 0.26),
      0 16px 34px rgba(54, 37, 9, 0.22);
  }

  /* No motion: drop the pull and the lift entirely; colour feedback stays. */
  @media (prefers-reduced-motion: reduce) {
    .btn--primary,
    .btn--secondary {
      transform: none;
      transition:
        background 0.45s var(--ease),
        color 0.45s var(--ease),
        border-color 0.45s var(--ease),
        box-shadow 0.45s var(--ease);
    }
  }

  /* Ghost outline: the subordinate sibling of the primary. It borrows the same
     shape (3px radius, shared footprint), the same gold accent, and the same
     lift — but stays a notch quieter by inverting the relationship. Where the
     primary is FILLED at rest and empties to an outline on hover, the secondary
     is an OUTLINE at rest and only warms toward gold on hover. A faint gold
     rest-border signals it's intentional and on-brand without competing for the
     eye, and the label sits at full body-text contrast so it's actually legible
     (the old muted-light text was the readability complaint). No magnetic pull:
     that channel stays exclusive to the primary. */
  .btn--secondary {
    --btn-border: hsla(42, 47%, 56%, 0.32);
    --btn-fg: var(--clr-body-text);
    --btn-bg-hover: rgba(196, 164, 90, 0.06);
    --btn-border-hover: var(--clr-primary-gold);
    --btn-fg-hover: var(--clr-primary-gold);
    /* A lighter echo of the primary's glow — tighter spread, lower alpha — so
       the secondary lifts without ever looking as loud. */
    --btn-shadow-hover:
      0 0 0 1px rgba(196, 164, 90, 0.08), 0 4px 18px rgba(196, 164, 90, 0.1),
      0 2px 6px rgba(0, 0, 0, 0.3);

    border-radius: 3px;
    border: 1.5px solid var(--btn-border);
    color: var(--btn-fg);

    /* Lift only (no magnetic --btn-mx/--btn-my): identity at rest, so no idle
       GPU layer; translate-only, so no layout/paint/CLS. */
    transform: translateY(var(--btn-lift, 0px));

    transition:
      background 0.45s var(--ease),
      color 0.45s var(--ease),
      border-color 0.45s var(--ease),
      transform 0.3s var(--ease),
      box-shadow 0.45s var(--ease);
  }

  .btn--secondary:hover {
    background: var(--btn-bg-hover);
    color: var(--btn-fg-hover);
    border-color: var(--btn-border-hover);
    --btn-lift: -2px;
    box-shadow: var(--btn-shadow-hover);

    /* Scoped to the hover, released on pointer-leave: the button is
       transform-animated for the whole lift. */
    will-change: transform;
  }

  .btn--secondary:active {
    --btn-lift: -1px;
  }
</style>
