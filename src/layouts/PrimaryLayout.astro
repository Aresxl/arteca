---
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import PageShutter from "@/components/helpers/PageShutter.astro";
import MetaHead from "./MetaHead.astro";

import "@/styles/global.css";

const { title, description, noindex } = Astro.props;
---

<!doctype html>
<html lang="en-AU">
  <MetaHead title={title} description={description} noindex={noindex} />
  <body>
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-K94TLQR6"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>
    <a href="#main" class="skip-to-main">Skip to main content</a>
    <PageShutter />
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>
      import "@/script/global.js";
    </script>
  </body>
</html>
