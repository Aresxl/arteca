---
const { title, description, canonical } = Astro.props;

const defaultCanonical = new URL(Astro.url.pathname, Astro.site).href;
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link
    rel="preload"
    href="/fonts/orbitron-v35-latin-900.woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />
  <link
    rel="preload"
    href="/fonts/orbitron-v35-latin-700.woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />
  <link
    rel="preload"
    href="/fonts/orbitron-v35-latin-regular.woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />
  <link
    rel="preload"
    href="/fonts/jetbrains-mono-v24-latin-regular.woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />

  <link rel="canonical" href={defaultCanonical} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="icon" type="image/png" href="/images/favicon.png" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  <meta name="format-detection" content="telephone=no" />

  <!-- Open Graph / Facebook, LinkedIn, etc. -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={defaultCanonical} />
  <meta property="og:site_name" content="Vyteca" />

  <!-- Twitter/X Cards -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:site" content="@Ares_HD" />
  <title>{title}</title>

  <script is:inline>
    (function () {
      window.dataLayer = window.dataLayer || [];

      function loadGTM() {
        if (window.__gtmLoaded) return;
        window.__gtmLoaded = true;
        window.dataLayer.push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var s = document.createElement("script");
        s.async = true;
        s.src = "https://www.googletagmanager.com/gtm.js?id=GTM-K94TLQR6";
        document.head.appendChild(s);
      }

      ["scroll", "pointerdown", "keydown", "mousemove"].forEach(function (evt) {
        window.addEventListener(evt, loadGTM, { once: true, passive: true });
      });

      if ("requestIdleCallback" in window) {
        requestIdleCallback(loadGTM, { timeout: 3000 });
      } else {
        setTimeout(loadGTM, 3000);
      }
    })();
  </script>
</head>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Vyteca",
    "url": "https://vyteca.com",
    "logo": "https://vyteca.com/images/vyteca-logo.png",
    "description": "Custom hand-coded websites for Melbourne restaurants. Lightning-fast loads, flawless mobile, local SEO foundations. More direct bookings and fuller tables. Built from scratch in 3–4 weeks.",
    "founder": {
      "@type": "Person",
      "name": "Lachlan Williams"
    },
    "foundingDate": "2026-02-17",
    "areaServed": {
      "@type": "Place",
      "name": "Melbourne, Victoria, Australia"
    },
    "serviceType": [
      "Restaurant Website Design",
      "Restaurant SEO",
      "Restaurant Performance Optimization",
      "Restaurant Conversion Optimization"
    ]
  }
</script>
