---
import { ClientRouter } from "astro:transitions";

const { title, description, noindex, ogImage } = Astro.props;

const defaultCanonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage ?? "/images/og-image.png", Astro.site).href;
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link
    rel="preload"
    href="/fonts/bricolage-grotesque-v9-latin-700.woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />
  <link
    rel="preload"
    href="/fonts/bricolage-grotesque-v9-latin-regular.woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />

  {noindex && <meta name="robots" content="noindex, follow" />}
  {!noindex && <link rel="canonical" href={defaultCanonical} />}
  {!noindex && <link rel="sitemap" href="/sitemap-index.xml" />}
  <link rel="icon" type="image/png" href="/images/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
  <link rel="shortcut icon" href="/images/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
  <link rel="manifest" href="/images/site.webmanifest" />
  <meta name="description" content={description} />
  <meta name="format-detection" content="telephone=no" />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_AU" />
  <meta property="og:url" content={defaultCanonical} />
  <meta property="og:site_name" content="Vyteca" />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={title} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <meta name="twitter:image:alt" content={title} />
  <title>{title}</title>

  <ClientRouter />

  <script is:inline>
    (function () {
      window.dataLayer = window.dataLayer || [];

      function loadGTM() {
        if (window.__gtmLoaded) return;
        window.__gtmLoaded = true;
        window.dataLayer.push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var s = document.createElement("script");
        s.async = true;
        s.src = "https://www.googletagmanager.com/gtm.js?id=GTM-K94TLQR6";
        document.head.appendChild(s);
      }

      var isLocal =
        window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1";

      if (isLocal) {
        loadGTM();
      } else {
        ["scroll", "pointerdown", "keydown", "mousemove"].forEach(function (evt) {
          window.addEventListener(evt, loadGTM, { once: true, passive: true });
        });

        if ("requestIdleCallback" in window) {
          requestIdleCallback(loadGTM, { timeout: 3000 });
        } else {
          setTimeout(loadGTM, 3000);
        }
      }
    })();
  </script>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://vyteca.com/#organization",
      "name": "Vyteca",
      "url": "https://vyteca.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://vyteca.com/images/web-app-manifest-512x512.png",
        "width": 512,
        "height": 512
      },
      "description": "Custom hand-coded websites for Melbourne hospitality businesses. Lightning-fast loads, flawless mobile, local SEO foundations. More direct bookings and fuller tables. Built from scratch and live in about a week.",
      "founder": {
        "@type": "Person",
        "name": "Lachlan Williams"
      },
      "foundingDate": "2026-02-17",
      "areaServed": {
        "@type": "City",
        "name": "Melbourne"
      },
      "knowsAbout": [
        "Hospitality Website Design",
        "Hospitality SEO",
        "Website Performance Optimization",
        "Conversion Rate Optimization"
      ],
      "sameAs": [
        "https://www.instagram.com/vyteca_studio/",
        "https://www.tiktok.com/@vyteca_studio",
        "https://www.youtube.com/@Vyteca"
      ]
    }
  </script>
</head>
