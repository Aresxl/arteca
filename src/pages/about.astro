---
// Data
import faqAbout from "@/data/faq-about.json";

// Assets
import founderHeadshot from "@/assets/images/desktop/headshot.jpeg";

// Components
import PrimaryLayout from "@/layouts/PrimaryLayout.astro";
import InnerPageHero from "@/components/sections/InnerPageHero.astro";
import Marquee from "@/components/sections/Marquee.astro";
import Founder from "@/components/sections/Founder.astro";
import WhyHandCoded from "@/components/sections/WhyHandCoded.astro";
import Process from "@/components/sections/Process.astro";
import FAQSection from "@/components/sections/FAQSection.astro";
import TripleGuarantee from "@/components/sections/TripleGuarantee.astro";
---

<PrimaryLayout
  title="About Vyteca | Melbourne Hospitality Web Designer"
  description="Meet Lachlan, the self-taught Melbourne developer behind Vyteca. I hand-build fast, custom websites for hospitality venues that turn visitors into bookings."
>
  <InnerPageHero
    title="About"
    subtitle={["One developer", "Full accountability"]}
    eyebrow="Who's behind Vyteca"
  />
  <Marquee
    items={[
      "One developer",
      "Direct contact",
      "Melbourne based",
      "Self-taught & obsessed",
      "No middlemen",
      "Full accountability",
      "Built from scratch",
      "Honest process",
    ]}
  />
  <Founder image={founderHeadshot} />
  <WhyHandCoded />
  <Process />
  <TripleGuarantee />
  <FAQSection
    items={faqAbout}
    titleLead="Common"
    titleAccent="questions"
    note="Quick answers to what most hospitality owners ask before getting started. Can’t find yours? <a href='/contact'>Get in touch</a>."
    viewAllHref="/faq"
  />
</PrimaryLayout>
