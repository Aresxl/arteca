---
import PrimaryLayout from "@/layouts/PrimaryLayout.astro";
import Packages from "@/components/sections/Packages.astro";
import Cta from "@/components/sections/Cta.astro";
import InnerPageHero from "@/components/sections/InnerPageHero.astro";
import SectionDivider from "@/components/ui/SectionDivider.astro";
import Testimonials from "@/components/sections/Testimonials.astro";
---

<PrimaryLayout
  title="Services | Vyteca"
  description="Affordable custom website packages for Melbourne restaurants. Hand-coded, no templates, blazing fast, SEO-ready. Simple pricing, clear value, designed to boost your tables and revenue."
>
  <InnerPageHero title="Services" subtitle="Tailored services to your unique restaurant" />
  <Packages />
  <SectionDivider />
  <Testimonials fadeIn={true} />
  <SectionDivider />
  <Cta />
</PrimaryLayout>
