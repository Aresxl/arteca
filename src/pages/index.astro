---
// Data
import faqHome from "@/data/faq-home.json";

// Components
import Hero from "@/components/sections/Hero.astro";
import OurOffer from "@/components/sections/OurOffer.astro";
import PrimaryLayout from "@/layouts/PrimaryLayout.astro";
import Portfolio from "@/components/sections/Portfolio.astro";
import Marquee from "@/components/sections/Marquee.astro";
import FAQSection from "@/components/sections/FAQSection.astro";
import TripleGuarantee from "@/components/sections/TripleGuarantee.astro";
import Membership from "@/components/sections/Membership.astro";
---

<PrimaryLayout
  title="Melbourne Hospitality Websites | Vyteca"
  description="Hand-coded websites for Melbourne hospitality venues. Faster loads, flawless mobile, more direct bookings. Built from scratch and live in about a week."
>
  <Hero />
  <Marquee />
  <OurOffer />
  <TripleGuarantee />
  <Portfolio fadeIn={true} />
  <Membership />
  <FAQSection
    items={faqHome}
    titleLead="Common"
    titleAccent="questions"
    note="Quick answers to what most hospitality owners ask before getting started. Can't find yours? <a href='/contact'>Get in touch</a>."
    viewAllHref="/faq"
  />
</PrimaryLayout>
